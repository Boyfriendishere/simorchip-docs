<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — Simorchip News</title>
<meta name="description" content="{{ excerpt }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<style>
{% include "tokens.css.njk" %}
.news-article{max-width:720px;margin:0 auto;text-align:left;}
.news-article-date{font-size:14px;color:var(--ink-48);margin-bottom:var(--sp-sm);}
.news-article-cover{width:100%;border-radius:var(--r-lg);margin-bottom:var(--sp-xl);display:block;}
.news-article-body{font-size:17px;line-height:1.6;color:var(--ink);}
.news-article-body h2{font-size:28px;margin:var(--sp-xl) 0 var(--sp-sm);}
.news-article-body p{margin-bottom:var(--sp-lg);}
.news-article-body img{max-width:100%;border-radius:var(--r-sm);}
.news-back{display:inline-block;margin-bottom:var(--sp-xl);color:var(--blue);text-decoration:none;}
</style>
</head>
<body>

{% include "nav.njk" %}

<div class="tile tile-light">
  <div class="tile-inner news-article">
    <a class="news-back" href="/news/">← Back to News</a>
    <div class="tile-eyebrow">News</div>
    <h1 class="tile-h2">{{ title }}</h1>
    <div class="news-article-date">{{ date | dateDisplay }}</div>
    {% if cover %}<img class="news-article-cover" src="{{ cover }}" alt="{{ title }}">{% endif %}
    <div class="news-article-body">
      {{ content | safe }}
    </div>
  </div>
</div>

{% include "footer.njk" %}
{% include "nav-script.njk" %}
</body>
</html>
