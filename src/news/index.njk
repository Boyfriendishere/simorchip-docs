<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>News — Simorchip</title>
<meta name="description" content="Latest news and updates from Simorchip.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<style>
{% include "tokens.css.njk" %}
.news-list{max-width:780px;margin:0 auto;text-align:left;display:flex;flex-direction:column;gap:var(--sp-xl);}
.news-card{display:flex;gap:var(--sp-lg);text-decoration:none;color:inherit;align-items:flex-start;}
.news-card-cover{width:160px;height:110px;object-fit:cover;border-radius:var(--r-sm);flex-shrink:0;background:var(--parchment);}
.news-card-date{font-size:14px;color:var(--ink-48);margin-bottom:4px;}
.news-card-title{font-size:21px;font-weight:600;margin-bottom:4px;}
.news-card-excerpt{font-size:15px;color:var(--ink-80);}
.news-card:hover .news-card-title{color:var(--blue);}
.news-empty{color:var(--ink-48);}
</style>
</head>
<body>

{% include "nav.njk" %}

<div class="tile tile-light">
  <div class="tile-inner">
    <div class="tile-eyebrow fade-in">Simorchip</div>
    <h1 class="tile-h2 fade-in fade-in-delay-1">News.</h1>
    <p class="tile-lead fade-in fade-in-delay-2">Latest announcements and updates.</p>
    <div class="news-list">
      {% for post in collections.news %}
      <a class="news-card fade-in" href="{{ post.url }}">
        {% if post.data.cover %}<img class="news-card-cover" src="{{ post.data.cover }}" alt="{{ post.data.title }}">{% endif %}
        <div>
          <div class="news-card-date">{{ post.data.date | dateDisplay }}</div>
          <div class="news-card-title">{{ post.data.title }}</div>
          <div class="news-card-excerpt">{{ post.data.excerpt }}</div>
        </div>
      </a>
      {% else %}
      <p class="news-empty">No news yet.</p>
      {% endfor %}
    </div>
  </div>
</div>

{% include "footer.njk" %}
{% include "nav-script.njk" %}
</body>
</html>
