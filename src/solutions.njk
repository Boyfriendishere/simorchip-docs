<script>
(function () {
  var nav = document.getElementById('globalNav');
  var heroBg = document.getElementById('heroBg');
  var sectionIds = ['consumer','gaming','business','industrial','creation','portable'];
  var sectionEls = sectionIds.map(function(id){ return document.getElementById(id); });
  var sectionBgs = sectionEls.map(function(el){ return el ? el.querySelector('.par-section-bg') : null; });
  var solNavItems = document.querySelectorAll('.sol-nav-item');

  function onScroll() {
    var sy = window.scrollY;
    var wh = window.innerHeight;

    heroBg.style.transform = 'translateY(' + (sy * 0.35) + 'px)';

    var heroBottom = document.getElementById('hero').getBoundingClientRect().bottom;
    if (heroBottom <= 0) {
      nav.classList.add('nav-scrolled-light');
    } else {
      nav.classList.remove('nav-scrolled-light');
    }

    sectionEls.forEach(function(section, i) {
      if (!section || !sectionBgs[i]) return;
      var rect = section.getBoundingClientRect();
      var progress = (wh - rect.top) / (wh + rect.height);
      sectionBgs[i].style.transform = 'translateY(' + ((progress - 0.5) * 120) + 'px)';
    });

    var current = '';
    sectionIds.forEach(function(id) {
      var el = document.getElementById(id);
      if (el && el.getBoundingClientRect().top <= wh * 0.4) current = id;
    });
    solNavItems.forEach(function(item) {
      item.classList.toggle('active', item.getAttribute('href') === '#' + current);
    });

    document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(function(el) {
      if (el.getBoundingClientRect().top < wh * 0.88) el.classList.add('visible');
    });
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>
</body>
</html>
