layout: false
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simorchip — Solutions for Every System</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,600;0,700;1,300&display=swap" rel="stylesheet">
<style>
:root {
  --blue: #0066cc;
  --blue-dark: #0071e3;
  --blue-ondark: #2997ff;
  --ink: #1d1d1f;
  --ink-80: #333333;
  --ink-48: #7a7a7a;
  --muted-dark: #cccccc;
  --white: #ffffff;
  --canvas: #ffffff;
  --parchment: #f5f5f7;
  --tile-1: #141414;
  --black: #000000;
  --hairline: #e0e0e0;
  --f: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  --r-sm: 8px;
  --r-lg: 18px;
  --r-pill: 9999px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: var(--f); background: var(--canvas); color: var(--ink); -webkit-font-smoothing: antialiased; overflow-x: hidden; padding-top: 44px; }

/* ══ NAV ══ */
.global-nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 300;
  height: 44px;
  display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
  padding: 0 22px;
  background: var(--black);
  transition: background .4s ease, backdrop-filter .4s ease, border-color .4s ease;
}
.global-nav.nav-scrolled-light {
  background: rgba(255,255,255,.88);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid rgba(0,0,0,.08);
}
.nav-logo { grid-column: 1; justify-self: start; }
.nav-logo img { height: 20px; display: block; filter: brightness(0) invert(1); opacity: .85; transition: filter .3s, opacity .3s; }
.nav-scrolled-light .nav-logo img { filter: brightness(0); opacity: 1; }
.nav-links { display: flex; align-items: center; gap: 20px; grid-column: 2; justify-self: center; }
.nav-link {
  position: relative;
  font-size: 12px; font-weight: 400; letter-spacing: -.12px; line-height: 1;
  color: rgba(255,255,255,.8); text-decoration: none;
  padding-bottom: 4px;
  transition: color .25s ease; white-space: nowrap;
}
.nav-link::after {
  content: ''; position: absolute; left: 0; right: 100%; bottom: -2px; height: 1px;
  background: var(--blue-ondark); transition: right .3s cubic-bezier(.16,1,.3,1);
}
.nav-link:hover { color: var(--white); }
.nav-link:hover::after { right: 0; }
.nav-scrolled-light .nav-link { color: var(--ink-80); }
.nav-scrolled-light .nav-link::after { background: var(--blue); }
.nav-scrolled-light .nav-link:hover { color: var(--blue); }
.nav-right { display: flex; align-items: center; gap: 8px; grid-column: 3; justify-self: end; }
.nav-lang-btn {
  font-size: 12px; font-weight: 400; letter-spacing: -.12px;
  color: rgba(255,255,255,.5); background: none; border: none; cursor: pointer;
  padding: 4px 8px; border-radius: var(--r-sm); transition: color .15s;
}
.nav-lang-btn:hover { color: var(--white); }
.nav-lang-btn.active { color: var(--white); }
.nav-scrolled-light .nav-lang-btn { color: var(--ink-48); }
.nav-scrolled-light .nav-lang-btn:hover { color: var(--ink); }
.nav-scrolled-light .nav-lang-btn.active { color: var(--ink); }
.nav-burger {
  display: none; flex-direction: column; gap: 4px;
  background: none; border: none; cursor: pointer; padding: 6px 4px;
}
.nav-burger span { display: block; width: 18px; height: 1.5px; background: rgba(255,255,255,.8); transition: all .22s; }
.nav-mobile {
  display: none; flex-direction: column;
  background: var(--black);
  position: fixed; top: 44px; left: 0; right: 0; z-index: 290;
  border-bottom: 1px solid rgba(255,255,255,.1);
}
.nav-mobile.open { display: flex; }
.nav-mobile-link {
  font-size: 17px; font-weight: 400; letter-spacing: -.374px; line-height: 1.47;
  color: rgba(255,255,255,.8); text-decoration: none;
  padding: 14px 22px; border-bottom: 1px solid rgba(255,255,255,.08);
  transition: color .15s;
}
.nav-mobile-link:hover { color: var(--white); }
.nav-mobile-lang { display: flex; gap: 8px; padding: 12px 22px; }

/* ══ PARALLAX HERO ══ */
.par-hero {
  position: relative;
  height: 100vh; min-height: 640px;
  display: flex; align-items: flex-end;
  overflow: hidden;
  background: var(--black);
  margin-top: -44px;
}
.par-hero-bg {
  position: absolute; inset: -20%;
  background: url('https://pub-03642ec28edd4da6bcaf414c061b4ad6.r2.dev/tile/ppt_03.jpg') center/cover no-repeat;
  opacity: .55;
  will-change: transform;
}
.par-hero-floor {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.85) 0%, rgba(0,0,0,.1) 60%, transparent 100%);
  pointer-events: none;
}
.par-hero-content {
  position: relative; z-index: 2;
  width: 100%; padding: 0 80px 80px;
}
.hero-label {
  font-size: 11px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
  color: var(--blue-ondark); margin-bottom: 16px;
  opacity: 0; animation: fadeUp .8s .3s forwards;
}
.hero-h1 {
  font-size: 72px; font-weight: 700; line-height: 1.04; letter-spacing: -.04em;
  color: var(--white); margin-bottom: 20px;
  opacity: 0; animation: fadeUp .8s .5s forwards;
}
.hero-h1 em { font-style: italic; font-weight: 300; color: rgba(255,255,255,.6); }
.hero-sub {
  font-size: 21px; font-weight: 400; line-height: 1.4; letter-spacing: -.02em;
  color: rgba(255,255,255,.65); max-width: 560px; margin-bottom: 36px;
  opacity: 0; animation: fadeUp .8s .7s forwards;
}
.hero-cta {
  display: flex; gap: 12px; flex-wrap: wrap;
  opacity: 0; animation: fadeUp .8s .9s forwards;
}
.scroll-cue {
  position: absolute; bottom: 28px; right: 80px; z-index: 3;
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  opacity: 0; animation: fadeUp .8s 1.2s forwards;
}
.scroll-cue span {
  font-size: 10px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
  color: rgba(255,255,255,.35); writing-mode: vertical-rl;
}
.scroll-line {
  width: 1px; height: 48px;
  background: linear-gradient(to bottom, rgba(255,255,255,.4), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}

/* ══ BUTTONS ══ */
.btn-pill {
  font-size: 15px; font-weight: 500; letter-spacing: -.02em;
  padding: 12px 26px; border-radius: var(--r-pill);
  text-decoration: none; border: 1.5px solid transparent;
  transition: transform .25s cubic-bezier(.16,1,.3,1), background .25s, border-color .25s, color .25s;
  cursor: pointer; display: inline-block;
}
.btn-pill:active { transform: scale(.96); }
.btn-blue { background: var(--blue); color: #fff; border-color: var(--blue); }
.btn-blue:hover { background: var(--blue-dark); transform: translateY(-2px); }
.btn-ghost-dark { background: transparent; color: #fff; border-color: rgba(255,255,255,.4); }
.btn-ghost-dark:hover { border-color: #fff; transform: translateY(-2px); }

/* ══ SOLUTION NAV STRIP ══ */
.sol-nav {
  position: sticky; top: 44px; z-index: 200;
  background: rgba(255,255,255,.9);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid var(--hairline);
  overflow-x: auto; scrollbar-width: none;
}
.sol-nav::-webkit-scrollbar { display: none; }
.sol-nav-inner {
  display: flex; align-items: center;
  max-width: 1200px; margin: 0 auto; padding: 0 40px;
}
.sol-nav-item {
  font-size: 13px; font-weight: 500; letter-spacing: -.01em; color: var(--ink-48);
  text-decoration: none; padding: 14px 18px; white-space: nowrap;
  border-bottom: 2px solid transparent;
  transition: color .2s, border-color .2s;
}
.sol-nav-item:hover { color: var(--ink); }
.sol-nav-item.active { color: var(--blue); border-bottom-color: var(--blue); }

/* ══ PARALLAX SECTIONS ══ */
.par-section {
  position: relative;
  min-height: 100vh;
  display: flex; flex-direction: column; justify-content: center;
  overflow: hidden;
}
.par-section-bg {
  position: absolute; inset: -25%;
  background-size: cover; background-position: center;
  will-change: transform;
}
.par-overlay { position: absolute; inset: 0; pointer-events: none; }
.par-light .par-overlay { background: rgba(255,255,255,.88); }
.par-light .par-section-bg { opacity: .15; }
.par-dark .par-overlay { background: linear-gradient(135deg, rgba(0,0,0,.92) 0%, rgba(10,10,30,.85) 100%); }
.par-dark .par-section-bg { opacity: .25; }
.par-accent .par-overlay { background: rgba(245,245,247,.92); }
.par-accent .par-section-bg { opacity: .12; }

.par-content {
  position: relative; z-index: 2;
  max-width: 1200px; margin: 0 auto; width: 100%;
  padding: 120px 80px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
}
.par-content.reverse { direction: rtl; }
.par-content.reverse > * { direction: ltr; }

/* ══ SECTION TYPOGRAPHY ══ */
.sec-index {
  font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase;
  margin-bottom: 14px;
}
.par-light .sec-index, .par-accent .sec-index { color: var(--blue); }
.par-dark .sec-index { color: var(--blue-ondark); }

.sec-h2 { font-size: 44px; font-weight: 700; line-height: 1.06; letter-spacing: -.04em; margin-bottom: 12px; }
.par-light .sec-h2, .par-accent .sec-h2 { color: var(--ink); }
.par-dark .sec-h2 { color: var(--white); }

.sec-tone { font-size: 19px; font-weight: 400; line-height: 1.4; letter-spacing: -.02em; margin-bottom: 18px; }
.par-light .sec-tone, .par-accent .sec-tone { color: var(--ink-80); }
.par-dark .sec-tone { color: rgba(255,255,255,.65); }

.sec-desc { font-size: 15px; font-weight: 400; line-height: 1.6; letter-spacing: -.01em; margin-bottom: 28px; max-width: 460px; }
.par-light .sec-desc, .par-accent .sec-desc { color: var(--ink-48); }
.par-dark .sec-desc { color: rgba(255,255,255,.5); }

.sec-label { font-size: 10px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; margin-bottom: 12px; }
.par-light .sec-label, .par-accent .sec-label { color: var(--ink-48); }
.par-dark .sec-label { color: rgba(255,255,255,.35); }

.sec-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px; }
.sec-chip { font-size: 13px; letter-spacing: -.01em; padding: 6px 14px; border-radius: var(--r-pill); border: 1px solid; }
.par-light .sec-chip, .par-accent .sec-chip { color: var(--ink-80); background: rgba(0,0,0,.04); border-color: rgba(0,0,0,.1); }
.par-dark .sec-chip { color: rgba(255,255,255,.8); background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.15); }

.text-link {
  font-size: 15px; font-weight: 500; color: var(--blue); text-decoration: none;
  display: inline-flex; align-items: center; gap: 6px;
  transition: gap .25s cubic-bezier(.16,1,.3,1);
}
.par-dark .text-link { color: var(--blue-ondark); }
.text-link:hover { gap: 10px; }
.text-link::after { content: '→'; font-size: 16px; }

/* ══ BENEFITS PANEL ══ */
.benefits-panel { padding: 32px; border-radius: var(--r-lg); }
.par-light .benefits-panel { background: rgba(0,0,0,.04); }
.par-dark .benefits-panel { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); }
.par-accent .benefits-panel { background: rgba(255,255,255,.7); border: 1px solid var(--hairline); }

.benefits-title { font-size: 10px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; margin-bottom: 20px; }
.par-light .benefits-title, .par-accent .benefits-title { color: var(--ink-48); }
.par-dark .benefits-title { color: rgba(255,255,255,.35); }

.benefits-list { list-style: none; display: flex; flex-direction: column; gap: 16px; }
.benefits-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 15px; line-height: 1.5; letter-spacing: -.01em; }
.par-light .benefits-list li, .par-accent .benefits-list li { color: var(--ink-80); }
.par-dark .benefits-list li { color: rgba(255,255,255,.75); }

.benefit-icon { flex-shrink: 0; width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: 1px; }
.par-light .benefit-icon, .par-accent .benefit-icon { background: rgba(0,102,204,.1); }
.par-dark .benefit-icon { background: rgba(41,151,255,.15); }
.benefit-icon svg { width: 10px; height: 10px; }
.par-light .benefit-icon svg, .par-accent .benefit-icon svg { stroke: var(--blue); }
.par-dark .benefit-icon svg { stroke: var(--blue-ondark); }

/* ══ OVERVIEW STRIP ══ */
.overview-strip { background: var(--black); padding: 100px 80px; position: relative; overflow: hidden; }
.overview-strip::before { content: ''; position: absolute; top: -1px; left: 0; right: 0; height: 80px; background: linear-gradient(to bottom, var(--canvas), transparent); }
.overview-inner { max-width: 1200px; margin: 0 auto; }
.overview-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--blue-ondark); margin-bottom: 12px; }
.overview-h2 { font-size: 48px; font-weight: 700; line-height: 1.08; letter-spacing: -.04em; color: var(--white); margin-bottom: 8px; max-width: 16ch; }
.overview-sub { font-size: 17px; color: rgba(255,255,255,.45); max-width: 52ch; line-height: 1.55; margin-bottom: 60px; }
.card-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
.sol-card {
  background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08);
  border-radius: var(--r-lg); padding: 28px; text-decoration: none;
  transition: background .35s, border-color .35s, transform .35s cubic-bezier(.16,1,.3,1);
  display: flex; flex-direction: column; gap: 8px;
}
.sol-card:hover { background: rgba(255,255,255,.09); border-color: rgba(41,151,255,.4); transform: translateY(-4px); }
.sol-card-num { font-size: 11px; font-weight: 700; letter-spacing: .1em; color: var(--blue-ondark); margin-bottom: 4px; }
.sol-card-title { font-size: 17px; font-weight: 600; letter-spacing: -.02em; color: var(--white); display: flex; align-items: center; justify-content: space-between; }
.sol-card-title::after { content: '›'; font-size: 20px; color: var(--blue-ondark); transition: transform .25s cubic-bezier(.16,1,.3,1); }
.sol-card:hover .sol-card-title::after { transform: translateX(4px); }
.sol-card-desc { font-size: 13px; color: rgba(255,255,255,.4); line-height: 1.5; letter-spacing: -.01em; }

/* ══ FINALE ══ */
.finale { background: var(--tile-1); padding: 120px 80px; }
.finale-inner { max-width: 1200px; margin: 0 auto; }
.finale-top { margin-bottom: 80px; }
.finale-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--blue-ondark); margin-bottom: 14px; }
.finale-h2 { font-size: 56px; font-weight: 700; letter-spacing: -.04em; line-height: 1.06; color: #fff; max-width: 14ch; margin-bottom: 18px; }
.finale-sub { font-size: 19px; color: rgba(255,255,255,.45); max-width: 48ch; line-height: 1.55; }
.pillars { border-top: 1px solid rgba(255,255,255,.08); }
.pillar { display: grid; grid-template-columns: 72px 1fr; gap: 24px; align-items: start; padding: 32px 0; border-bottom: 1px solid rgba(255,255,255,.06); transition: border-bottom-color .3s; }
.pillar:hover { border-bottom-color: rgba(255,255,255,.18); }
.pillar-num { font-size: 11px; font-weight: 700; letter-spacing: .1em; color: var(--blue-ondark); padding-top: 5px; }
.pillar-title { font-size: 21px; font-weight: 600; color: #fff; margin-bottom: 8px; letter-spacing: -.02em; }
.pillar-body { font-size: 15px; color: rgba(255,255,255,.45); max-width: 60ch; line-height: 1.6; }
.finale-foot { display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; margin-top: 60px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,.08); }
.finale-foot-label { font-size: 17px; color: rgba(255,255,255,.45); max-width: 44ch; line-height: 1.55; }
.finale-cta { display: flex; gap: 12px; flex-wrap: wrap; }

/* ══ FOOTER ══ */
footer { background: var(--parchment); padding: 64px 80px; border-top: 1px solid var(--hairline); }
.footer-inner { max-width: 1200px; margin: 0 auto; }
.footer-top { display: flex; align-items: flex-start; gap: 80px; padding-bottom: 48px; border-bottom: 1px solid var(--hairline); margin-bottom: 20px; }
.footer-logo img { height: 24px; display: block; object-fit: contain; }
.footer-col-title { font-size: 14px; font-weight: 600; letter-spacing: -.224px; line-height: 1.29; color: var(--ink-48); margin-bottom: 12px; }
.footer-nav { display: flex; flex-direction: column; gap: 10px; }
.footer-nav a { font-size: 14px; font-weight: 400; line-height: 1.43; letter-spacing: -.224px; color: var(--ink-80); text-decoration: none; transition: color .15s; }
.footer-nav a:hover { color: var(--blue); }
.footer-row { display: flex; align-items: baseline; gap: 12px; }
.footer-key { font-size: 14px; font-weight: 600; letter-spacing: -.224px; line-height: 1.29; color: var(--ink-48); width: 44px; flex-shrink: 0; }
.footer-val { font-size: 17px; font-weight: 400; line-height: 2.41; letter-spacing: 0; color: var(--ink-80); }
.footer-val a { color: var(--blue); text-decoration: none; }
.footer-val a:hover { text-decoration: underline; }
.footer-bottom { font-size: 12px; font-weight: 400; line-height: 1; letter-spacing: -.12px; color: var(--ink-48); }

/* ══ SCROLL ANIMATIONS ══ */
.reveal { opacity: 0; transform: translateY(32px); transition: opacity .7s ease, transform .7s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
.reveal-delay-1 { transition-delay: .1s; }
.reveal-delay-2 { transition-delay: .2s; }
.reveal-delay-3 { transition-delay: .3s; }
.reveal-left { opacity: 0; transform: translateX(-32px); transition: opacity .7s ease, transform .7s ease; }
.reveal-left.visible { opacity: 1; transform: translateX(0); }
.reveal-right { opacity: 0; transform: translateX(32px); transition: opacity .7s ease, transform .7s ease; }
.reveal-right.visible { opacity: 1; transform: translateX(0); }

/* ══ KEYFRAMES ══ */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes scrollPulse {
  0%,100% { transform: scaleY(1); opacity: .4; }
  50% { transform: scaleY(.6); opacity: 1; }
}

/* ══ RWD ══ */
@media (max-width: 1068px) {
  .hero-h1 { font-size: 52px; }
  .par-content { padding: 100px 48px; gap: 48px; }
  .card-grid { grid-template-columns: 1fr 1fr; }
  .overview-strip, .finale { padding: 80px 48px; }
}
@media (max-width: 834px) {
  .nav-links { display: none; }
  .nav-burger { display: flex; }
  .par-content { grid-template-columns: 1fr; padding: 80px 32px; gap: 36px; }
  .par-content.reverse { direction: ltr; }
  .hero-h1 { font-size: 40px; }
  .hero-sub { font-size: 17px; }
  .par-hero-content { padding: 0 32px 64px; }
  .sec-h2 { font-size: 34px; }
  .card-grid { grid-template-columns: 1fr; }
  .overview-strip, .finale { padding: 80px 32px; }
  .overview-h2, .finale-h2 { font-size: 38px; }
  .pillar { grid-template-columns: 1fr; gap: 4px; }
  .pillar-num { padding-top: 0; }
  .finale-foot { flex-direction: column; }
  footer { padding: 48px 32px; }
  .footer-top { flex-direction: column; gap: 32px; }
  .sol-nav-inner { padding: 0 16px; }
  .scroll-cue { right: 32px; }
}
@media (max-width: 640px) {
  .hero-h1 { font-size: 32px; }
  .sec-h2 { font-size: 28px; }
  .finale-h2 { font-size: 32px; }
  footer { padding: 40px 22px; }
}
</style>
</head>
<body>

{% include "nav.njk" %}

<!-- ══ PARALLAX HERO ══ -->
<section class="par-hero" id="hero">
  <div class="par-hero-bg" id="heroBg"></div>
  <div class="par-hero-floor"></div>
  <div class="par-hero-content">
    <div class="hero-label">Solutions</div>
    <h1 class="hero-h1">Solutions for<br><em>Every System.</em></h1>
    <p class="hero-sub">Storage, memory, graphics, and external solutions designed for real-world systems — from personal upgrades to commercial deployment.</p>
    <div class="hero-cta">
      <a class="btn-pill btn-blue" href="product.html">Explore Products</a>
      <a class="btn-pill btn-ghost-dark" href="contact.html">Contact Us</a>
    </div>
  </div>
  <div class="scroll-cue">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- ══ OVERVIEW STRIP ══ -->
<section class="overview-strip">
  <div class="overview-inner">
    <div class="overview-eyebrow reveal">Browse by need</div>
    <h2 class="overview-h2 reveal reveal-delay-1">Solutions by application.</h2>
    <p class="overview-sub reveal reveal-delay-2">Start from the scenario closest to your build. Each path maps real usage to the right mix of storage, memory, and graphics.</p>
