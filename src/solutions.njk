{% include "nav-script.njk" %}

<script>
(function(){
  var nav     = document.getElementById('globalNav');
  var heroBg  = document.getElementById('heroBg');
  var heroSec = document.getElementById('heroSec');
  var imgs    = document.querySelectorAll('.sp-img');
  var snItems = document.querySelectorAll('.sn-item');
  var secIds  = ['s01','s02','s03','s04','s05','s06'];
  var secEls  = secIds.map(function(id){ return document.getElementById(id); });
  var raf = null;

  function tick(){
    var sy = window.scrollY, wh = window.innerHeight;

    heroBg.style.transform = 'translateY('+Math.round(sy * 0.38)+'px)';

    imgs.forEach(function(img){
      var rect = img.parentElement.getBoundingClientRect();
      var prog = (wh - rect.top) / (wh + rect.height);
      img.style.transform = 'translateY('+Math.round((prog - 0.5) * -32)+'px)';
    });

    var heroBot = heroSec.getBoundingClientRect().bottom;
    nav.className = 'global-nav ' + (heroBot > 44 ? 'transparent' : 'frosted-dark');

    var active = '';
    secEls.forEach(function(el,i){
      if(el && el.getBoundingClientRect().top <= wh * 0.45) active = secIds[i];
    });
    snItems.forEach(function(item){
      item.classList.toggle('active', item.getAttribute('href') === '#'+active);
    });

    document.querySelectorAll('.fu').forEach(function(el){
      if(el.getBoundingClientRect().top < wh * 0.88) el.classList.add('in');
    });

    raf = null;
  }

  window.addEventListener('scroll', function(){ if(!raf) raf = requestAnimationFrame(tick); },{passive:true});
  tick();
})();
</script>
</body>
</html>
