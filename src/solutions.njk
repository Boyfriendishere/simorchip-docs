<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simorchip — Solutions for Every System</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;1,14..32,300;1,14..32,400&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#1d1d1f;--ink-60:#555558;--ink-40:#86868b;
  --canvas:#fff;--parch:#f5f5f7;
  --dark:#060608;--panel:#0d0d10;
  --f:Inter,system-ui,-apple-system,sans-serif;--pill:9999px;
}
#s01{--acc:#2997ff;--acc-dim:rgba(41,151,255,.07);--acc-glow:rgba(41,151,255,.22)}
#s02{--acc:#b06ef0;--acc-dim:rgba(176,110,240,.08);--acc-glow:rgba(176,110,240,.22)}
#s03{--acc:#2ec4a9;--acc-dim:rgba(46,196,169,.07);--acc-glow:rgba(46,196,169,.20)}
#s04{--acc:#f5a623;--acc-dim:rgba(245,166,35,.07);--acc-glow:rgba(245,166,35,.22)}
#s05{--acc:#f0609e;--acc-dim:rgba(240,96,158,.08);--acc-glow:rgba(240,96,158,.22)}
#s06{--acc:#30d158;--acc-dim:rgba(48,209,88,.07);--acc-glow:rgba(48,209,88,.20)}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--f);background:var(--canvas);-webkit-font-smoothing:antialiased;overflow-x:hidden;padding-top:44px}

/* ── GLOBAL NAV ── */
.global-nav{
  position:fixed;top:0;left:0;right:0;z-index:500;height:44px;
  display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 22px;
  transition:background .4s,border-color .4s;
}
.global-nav.transparent{background:transparent}
.global-nav.frosted-dark{background:rgba(6,6,8,.75);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid rgba(255,255,255,.06)}
.global-nav.frosted-light{background:rgba(255,255,255,.84);backdrop-filter:blur(24px) saturate(180%);-webkit-backdrop-filter:blur(24px) saturate(180%);border-bottom:1px solid rgba(0,0,0,.08)}
.nav-logo img{height:20px;display:block;transition:filter .4s}
.global-nav.transparent .nav-logo img,.global-nav.frosted-dark .nav-logo img{filter:brightness(0) invert(1) opacity(.82)}
.global-nav.frosted-light .nav-logo img{filter:brightness(0)}
.nav-links{grid-column:2;display:flex;gap:20px}
.nav-link{font-size:12px;text-decoration:none;letter-spacing:-.01em;transition:color .2s}
.global-nav.transparent .nav-link,.global-nav.frosted-dark .nav-link{color:rgba(255,255,255,.68)}
.global-nav.transparent .nav-link:hover,.global-nav.frosted-dark .nav-link:hover{color:#fff}
.global-nav.frosted-light .nav-link{color:var(--ink-60)}
.global-nav.frosted-light .nav-link:hover{color:#0066cc}
.nav-right{grid-column:3;justify-self:end;display:flex;align-items:center;gap:6px}
.nav-lang-btn{font-size:12px;background:none;border:none;cursor:pointer;padding:4px 8px;border-radius:6px;transition:color .2s}
.global-nav.transparent .nav-lang-btn,.global-nav.frosted-dark .nav-lang-btn{color:rgba(255,255,255,.3)}
.global-nav.transparent .nav-lang-btn.active,.global-nav.transparent .nav-lang-btn:hover,
.global-nav.frosted-dark .nav-lang-btn.active,.global-nav.frosted-dark .nav-lang-btn:hover{color:#fff}
.global-nav.frosted-light .nav-lang-btn{color:var(--ink-40)}
.global-nav.frosted-light .nav-lang-btn.active,.global-nav.frosted-light .nav-lang-btn:hover{color:var(--ink)}
.nav-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px}
.nav-burger span{display:block;width:20px;height:1.5px;background:currentColor;transition:transform .3s,opacity .3s}
.global-nav.transparent .nav-burger,.global-nav.frosted-dark .nav-burger{color:#fff}
.global-nav.frosted-light .nav-burger{color:var(--ink)}
.nav-mobile{display:none;position:fixed;top:44px;left:0;right:0;bottom:0;background:rgba(6,6,8,.96);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);flex-direction:column;padding:32px 24px;gap:4px;z-index:490;transform:translateY(-8px);opacity:0;pointer-events:none;transition:transform .3s,opacity .3s}
.nav-mobile.open{transform:none;opacity:1;pointer-events:auto}
.nav-mobile-link{font-size:22px;font-weight:600;color:#fff;text-decoration:none;padding:14px 0;border-bottom:1px solid rgba(255,255,255,.07);letter-spacing:-.03em}
.nav-mobile-lang{display:flex;gap:12px;margin-top:24px}

@media(max-width:834px){
  .nav-links{display:none}
  .nav-burger{display:flex}
  .nav-mobile{display:flex}
}

/* ── HERO ── */
.hero{position:relative;height:100vh;min-height:680px;overflow:hidden;background:var(--dark);margin-top:-44px;display:flex;align-items:flex-end}
.hero-bg{position:absolute;inset:-20%;will-change:transform;background:url('https://pub-03642ec28edd4da6bcaf414c061b4ad6.r2.dev/tile/ppt_03.jpg') center/cover no-repeat;opacity:.42}
.hero-grad{position:absolute;inset:0;pointer-events:none;background:linear-gradient(to top,rgba(6,6,8,.96) 0%,rgba(6,6,8,.32) 52%,transparent 100%)}
.hero-body{position:relative;z-index:2;padding:0 80px 100px}
.hero-kicker{font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:#2997ff;margin-bottom:20px;opacity:0;animation:up .9s .3s forwards}
.hero-h1{font-size:88px;font-weight:800;line-height:1.0;letter-spacing:-.06em;color:#fff;margin-bottom:22px;opacity:0;animation:up .9s .5s forwards}
.hero-h1 em{font-style:italic;font-weight:300;color:rgba(255,255,255,.35)}
.hero-sub{font-size:20px;font-weight:400;line-height:1.55;color:rgba(255,255,255,.44);max-width:520px;margin-bottom:44px;opacity:0;animation:up .9s .7s forwards}
.hero-cta{display:flex;gap:14px;flex-wrap:wrap;opacity:0;animation:up .9s .9s forwards}
.scroll-hint{position:absolute;bottom:38px;right:80px;z-index:2;display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0;animation:up .9s 1.2s forwards}
.scroll-hint-label{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.2);writing-mode:vertical-rl}
.scroll-hint-line{width:1px;height:56px;background:linear-gradient(to bottom,rgba(255,255,255,.42),transparent);animation:pulse 2.2s ease-in-out infinite}

/* ── BUTTONS ── */
.btn{font-size:15px;font-weight:500;padding:13px 28px;border-radius:var(--pill);text-decoration:none;display:inline-block;border:1.5px solid transparent;transition:transform .3s cubic-bezier(.16,1,.3,1),background .25s,border-color .25s;cursor:pointer}
.btn:active{transform:scale(.96)!important}
.btn-solid{background:#0066cc;color:#fff;border-color:#0066cc}
.btn-solid:hover{background:#0071e3;transform:translateY(-2px)}
.btn-ghost-w{background:transparent;color:#fff;border-color:rgba(255,255,255,.28)}
.btn-ghost-w:hover{border-color:#fff;transform:translateY(-2px)}

/* ── OVERVIEW GRID ── */
.grid-strip{background:var(--dark);padding:100px 80px;position:relative}
.grid-strip::before{content:'';position:absolute;top:0;left:0;right:0;height:90px;background:linear-gradient(to bottom,var(--canvas),transparent);pointer-events:none}
.gs-inner{max-width:1200px;margin:0 auto}
.gs-label{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#2997ff;margin-bottom:14px}
.gs-h2{font-size:52px;font-weight:800;letter-spacing:-.05em;line-height:1.04;color:#fff;margin-bottom:12px}
.gs-sub{font-size:17px;color:rgba(255,255,255,.3);line-height:1.62;max-width:52ch;margin-bottom:60px}
.gs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.06);border-radius:16px;overflow:hidden}
.gs-card{background:rgba(255,255,255,.03);padding:30px 26px;text-decoration:none;display:flex;flex-direction:column;gap:9px;transition:background .28s}
.gs-card:hover{background:rgba(255,255,255,.08)}
.gs-num{font-size:11px;font-weight:700;letter-spacing:.12em;color:#2997ff}
.gs-title{font-size:17px;font-weight:600;color:#fff;letter-spacing:-.02em;display:flex;justify-content:space-between;align-items:center}
.gs-title::after{content:'›';font-size:22px;color:rgba(255,255,255,.3);transition:transform .25s cubic-bezier(.16,1,.3,1),color .25s}
.gs-card:hover .gs-title::after{transform:translateX(5px);color:#2997ff}
.gs-desc{font-size:13px;color:rgba(255,255,255,.26);line-height:1.55}

/* ── SOL-NAV ── */
.sol-nav{position:sticky;top:44px;z-index:400;background:rgba(255,255,255,.88);backdrop-filter:blur(24px) saturate(180%);-webkit-backdrop-filter:blur(24px) saturate(180%);border-bottom:1px solid rgba(0,0,0,.08);overflow-x:auto;scrollbar-width:none}
.sol-nav::-webkit-scrollbar{display:none}
.sol-nav-inner{display:flex;max-width:1200px;margin:0 auto;padding:0 40px}
.sn-item{font-size:12px;font-weight:500;color:var(--ink-40);text-decoration:none;padding:14px 18px;white-space:nowrap;border-bottom:2px solid transparent;transition:color .18s,border-color .18s}
.sn-item:hover{color:var(--ink)}
.sn-item.active{color:#0066cc;border-bottom-color:#0066cc}

/* ── SPLIT SECTIONS ── */
.sp-section{
  display:grid;grid-template-columns:1fr 1fr;
  min-height:90vh;background:var(--dark);
  scroll-margin-top:88px;overflow:hidden;position:relative;
}
.sp-section+.sp-section::before{
  content:'';position:absolute;top:0;left:5%;right:5%;height:1px;
  background:linear-gradient(to right,transparent,rgba(255,255,255,.06) 30%,rgba(255,255,255,.06) 70%,transparent);
  pointer-events:none;z-index:10;
}
.sp-section.text-left  .sp-text{order:1}
.sp-section.text-left  .sp-img-wrap{order:2}
.sp-section.text-right .sp-img-wrap{order:1}
.sp-section.text-right .sp-text{order:2}

.sp-text{
  display:flex;flex-direction:column;justify-content:center;
  padding:80px 60px;background:var(--panel);
  position:relative;overflow:hidden;
}
.sp-text::before{
  content:attr(data-n);position:absolute;
  font-size:320px;font-weight:800;letter-spacing:-.06em;line-height:1;
  color:var(--acc);opacity:.04;
  bottom:-60px;right:-24px;pointer-events:none;user-select:none;
}
.sp-section.text-left  .sp-text::after{content:'';position:absolute;top:12%;right:0;bottom:12%;width:1px;background:linear-gradient(to bottom,transparent,var(--acc) 40%,var(--acc) 60%,transparent);opacity:.18}
.sp-section.text-right .sp-text::after{content:'';position:absolute;top:12%;left:0;bottom:12%;width:1px;background:linear-gradient(to bottom,transparent,var(--acc) 40%,var(--acc) 60%,transparent);opacity:.18}

.sp-img-wrap{
  display:flex;align-items:center;justify-content:center;
  background:var(--acc-dim);position:relative;overflow:hidden;
  padding:48px 40px;transition:background .4s;
}
.sp-img-wrap::before{
  content:'';position:absolute;inset:0;z-index:1;pointer-events:none;
  background:
    linear-gradient(to bottom,rgba(6,6,8,.48) 0%,transparent 16%),
    linear-gradient(to top,   rgba(6,6,8,.48) 0%,transparent 16%),
    linear-gradient(to right, rgba(6,6,8,.38) 0%,transparent 14%),
    linear-gradient(to left,  rgba(6,6,8,.38) 0%,transparent 14%);
}
.sp-img-wrap::after{
  content:'';position:absolute;width:60%;padding-bottom:60%;border-radius:50%;
  background:radial-gradient(circle,var(--acc-glow) 0%,transparent 70%);
  opacity:.5;pointer-events:none;z-index:0;
}
.sp-img{
  display:block;width:100%;max-height:68vh;object-fit:contain;
  will-change:transform;position:relative;z-index:2;
  border-radius:8px;box-shadow:0 24px 64px rgba(0,0,0,.7),0 0 0 1px rgba(255,255,255,.05);
}

.sp-num{font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--acc);margin-bottom:16px;display:flex;align-items:center;gap:10px}
.sp-num::after{content:'';flex:1;height:1px;background:linear-gradient(to right,var(--acc),transparent);opacity:.3;max-width:64px}
.sp-h2{font-size:46px;font-weight:800;line-height:1.04;letter-spacing:-.05em;color:#fff;margin-bottom:10px}
.sp-tone{font-size:17px;font-weight:400;line-height:1.48;color:rgba(255,255,255,.5);margin-bottom:16px;font-style:italic}
.sp-desc{font-size:15px;line-height:1.72;color:rgba(255,255,255,.38);margin-bottom:26px;max-width:40ch}
.sp-chips-label{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.24);margin-bottom:10px}
.sp-chips{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:26px}
.sp-chip{font-size:12px;padding:5px 13px;border-radius:var(--pill);color:var(--acc);background:var(--acc-dim);border:1px solid rgba(255,255,255,.1);letter-spacing:-.01em}
.sp-link{font-size:14px;font-weight:500;color:var(--acc);text-decoration:none;display:inline-flex;align-items:center;gap:7px;transition:gap .25s cubic-bezier(.16,1,.3,1);margin-bottom:28px}
.sp-link:hover{gap:12px}
.sp-link::after{content:'→';font-size:15px}
.sp-benefits{list-style:none;display:flex;flex-direction:column;gap:10px;padding-top:22px;border-top:1px solid rgba(255,255,255,.07)}
.sp-benefits li{display:flex;align-items:flex-start;gap:11px;font-size:14px;line-height:1.55;color:rgba(255,255,255,.46)}
.sp-bicon{flex-shrink:0;width:20px;height:20px;border-radius:50%;background:var(--acc-dim);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;margin-top:2px}
.sp-bicon svg{width:9px;height:9px;stroke:var(--acc)}

/* ── FINALE ── */
.finale{background:var(--dark);padding:130px 80px;border-top:1px solid rgba(255,255,255,.05)}
.finale-inner{max-width:1200px;margin:0 auto}
.f-eyebrow{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#2997ff;margin-bottom:16px}
.f-h2{font-size:60px;font-weight:800;letter-spacing:-.055em;line-height:1.04;color:#fff;max-width:14ch;margin-bottom:18px}
.f-sub{font-size:18px;color:rgba(255,255,255,.3);max-width:46ch;line-height:1.62;margin-bottom:72px}
.pillars{border-top:1px solid rgba(255,255,255,.07)}
.pillar{display:grid;grid-template-columns:80px 1fr;gap:24px;align-items:start;padding:32px 0;border-bottom:1px solid rgba(255,255,255,.05);transition:border-color .3s}
.pillar:hover{border-color:rgba(255,255,255,.16)}
.p-num{font-size:11px;font-weight:700;letter-spacing:.1em;color:#2997ff;padding-top:5px}
.p-title{font-size:22px;font-weight:600;color:#fff;margin-bottom:7px;letter-spacing:-.02em}
.p-body{font-size:15px;color:rgba(255,255,255,.3);max-width:58ch;line-height:1.65}
.finale-foot{display:flex;align-items:center;justify-content:space-between;gap:32px;flex-wrap:wrap;margin-top:64px;padding-top:44px;border-top:1px solid rgba(255,255,255,.07)}
.f-foot-txt{font-size:18px;color:rgba(255,255,255,.3);max-width:44ch;line-height:1.55}
.f-cta{display:flex;gap:14px;flex-wrap:wrap}

/* ── FOOTER ── */
footer{background:var(--parch);padding:64px 80px;border-top:1px solid rgba(0,0,0,.08)}
.footer-inner{max-width:1200px;margin:0 auto}
.footer-top{display:flex;gap:80px;padding-bottom:44px;border-bottom:1px solid rgba(0,0,0,.08);margin-bottom:20px;flex-wrap:wrap}
.footer-logo img{height:24px;display:block}
.footer-col-title{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-40);margin-bottom:14px}
.footer-nav{display:flex;flex-direction:column;gap:4px}
.footer-nav a{font-size:14px;color:var(--ink-60);text-decoration:none;padding:4px 0;transition:color .15s}
.footer-nav a:hover{color:#0066cc}
.footer-info{display:flex;flex-direction:column}
.footer-row{display:flex;gap:14px}
.footer-key{font-size:13px;font-weight:600;color:var(--ink-40);width:52px;flex-shrink:0;line-height:2}
.footer-val{font-size:14px;color:var(--ink-60);line-height:2}
.footer-val a{color:#0066cc;text-decoration:none}
.footer-val a:hover{text-decoration:underline}
.footer-bottom{font-size:12px;color:var(--ink-40)}

/* ── ANIMATIONS ── */
.fu{opacity:0;transform:translateY(26px);transition:opacity .75s ease,transform .75s ease}
.fu.in{opacity:1;transform:none}
.d1{transition-delay:.08s}.d2{transition-delay:.16s}.d3{transition-delay:.24s}.d4{transition-delay:.32s}
@keyframes up{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
@keyframes pulse{0%,100%{opacity:.28}50%{opacity:.8}}

/* ── RWD ── */
@media(max-width:1068px){
  .hero-h1{font-size:64px}
  .sp-h2{font-size:36px}
  .gs-h2{font-size:44px}
  .f-h2{font-size:46px}
  .grid-strip,.finale{padding:80px 48px}
  .sp-text{padding:60px 44px}
  footer{padding:52px 48px}
  .sp-text::before{font-size:240px}
}
@media(max-width:834px){
  .sp-section{grid-template-columns:1fr;min-height:unset}
  .sp-section.text-left .sp-text,.sp-section.text-right .sp-text{order:2;padding:48px 32px}
  .sp-section.text-left .sp-img-wrap,.sp-section.text-right .sp-img-wrap{order:1;min-height:48vw;padding:32px}
  .sp-img{max-height:46vw}
  .sp-text::before{display:none}
  .sp-h2{font-size:30px}
  .hero-h1{font-size:44px}.hero-body{padding:0 32px 72px}
  .scroll-hint{right:32px}
  .gs-grid{grid-template-columns:1fr 1fr}
  .grid-strip,.finale{padding:72px 32px}
  .gs-h2,.f-h2{font-size:34px}
  .pillar{grid-template-columns:1fr;gap:6px}.p-num{padding-top:0}
  .finale-foot{flex-direction:column}
  footer{padding:48px 32px}.footer-top{gap:36px}
  .sol-nav-inner{padding:0 16px}
}
@media(max-width:600px){
  .hero-h1{font-size:36px}
  .sp-h2{font-size:26px}
  .gs-grid{grid-template-columns:1fr}
  .f-h2{font-size:30px}
  .grid-strip,.finale{padding:60px 22px}
  footer{padding:40px 22px}
}
</style>
</head>
<body>

{% include "nav.njk" %}

<!-- HERO -->
<section class="hero" id="heroSec">
  <div class="hero-bg" id="heroBg"></div>
  <div class="hero-grad"></div>
  <div class="hero-body">
    <div class="hero-kicker">Solutions</div>
    <h1 class="hero-h1">Solutions for<br><em>Every System.</em></h1>
    <p class="hero-sub">Storage, memory, graphics, and external solutions designed for real-world systems — from personal upgrades to commercial deployment.</p>
    <div class="hero-cta">
      <a class="btn btn-solid" href="/product.html">Explore Products</a>
      <a class="btn btn-ghost-w" href="/contact.html">Contact Us</a>
    </div>
  </div>
  <div class="scroll-hint"><span class="scroll-hint-label">Scroll</span><div class="scroll-hint-line"></div></div>
</section>

<!-- OVERVIEW GRID -->
<section class="grid-strip">
  <div class="gs-inner">
    <div class="gs-label fu">Browse by need</div>
    <h2 class="gs-h2 fu d1">Solutions by application.</h2>
    <p class="gs-sub fu d2">Start from the scenario closest to your build. Each path maps real usage to the right mix of storage, memory, and graphics.</p>
    <div class="gs-grid">
      <a class="gs-card fu"    href="#s01"><div class="gs-num">01</div><div class="gs-title">Consumer Upgrade</div><div class="gs-desc">Faster everyday desktops and laptops.</div></a>
      <a class="gs-card fu d1" href="#s02"><div class="gs-num">02</div><div class="gs-title">Gaming &amp; Performance</div><div class="gs-desc">Speed, responsiveness, and visual power.</div></a>
      <a class="gs-card fu d2" href="#s03"><div class="gs-num">03</div><div class="gs-title">Business &amp; Office</div><div class="gs-desc">Stable upgrades for productivity.</div></a>
      <a class="gs-card fu"    href="#s04"><div class="gs-num">04</div><div class="gs-title">Industrial &amp; Embedded</div><div class="gs-desc">Reliable parts for long-running systems.</div></a>
      <a class="gs-card fu d1" href="#s05"><div class="gs-num">05</div><div class="gs-title">Content Creation</div><div class="gs-desc">Throughput for heavy creative work.</div></a>
      <a class="gs-card fu d2" href="#s06"><div class="gs-num">06</div><div class="gs-title">Portable &amp; External</div><div class="gs-desc">Storage that travels with you.</div></a>
    </div>
  </div>
</section>

<!-- SOL-NAV -->
<div class="sol-nav" id="solNav">
  <div class="sol-nav-inner">
    <a class="sn-item" href="#s01">Consumer</a>
    <a class="sn-item" href="#s02">Gaming</a>
    <a class="sn-item" href="#s03">Business</a>
