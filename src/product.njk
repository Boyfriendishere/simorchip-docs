---
permalink: /product.html
eleventyExcludeFromCollections: true
layout: false
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Products — Simorchip</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<style>
:root{--blue:#0066cc;--blue-dark:#0071e3;--blue-ondark:#2997ff;--ink:#1d1d1f;--ink-80:#333333;--ink-48:#7a7a7a;--white:#ffffff;--canvas:#ffffff;--parchment:#f5f5f7;--black:#000000;--hairline:#e0e0e0;--sp-sm:12px;--sp-md:17px;--sp-lg:24px;--sp-xl:32px;--sp-xxl:48px;--sp-section:80px;--f:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;--r-pill:9999px;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:var(--f);background:var(--canvas);color:var(--ink);-webkit-font-smoothing:antialiased;padding-top:44px;}

/* ─── Nav ─── */
.global-nav{position:fixed;top:0;left:0;right:0;z-index:300;background:var(--black);height:44px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 22px;}
.nav-logo{grid-column:1;justify-self:start;}
.nav-logo img{height:20px;display:block;filter:brightness(0) invert(1);opacity:.85;}
.nav-links{display:flex;align-items:center;gap:20px;grid-column:2;justify-self:center;}
.nav-link{position:relative;font-size:12px;font-weight:400;letter-spacing:-.12px;line-height:1;color:rgba(255,255,255,.8);text-decoration:none;padding-bottom:4px;transition:color .25s;white-space:nowrap;}
.nav-link::after{content:'';position:absolute;left:0;right:100%;bottom:-2px;height:1px;background:var(--blue-ondark);transition:right .3s cubic-bezier(.16,1,.3,1);}
.nav-link:hover{color:var(--white);}
.nav-link:hover::after{right:0;}
.nav-right{display:flex;align-items:center;gap:8px;grid-column:3;justify-self:end;}
.nav-lang-btn{font-size:12px;font-weight:400;letter-spacing:-.12px;color:rgba(255,255,255,.5);background:none;border:none;cursor:pointer;padding:4px 8px;border-radius:8px;transition:color .15s;}
.nav-lang-btn:hover,.nav-lang-btn.active{color:var(--white);}
.nav-burger{display:none;flex-direction:column;gap:4px;background:none;border:none;cursor:pointer;padding:6px 4px;}
.nav-burger span{display:block;width:18px;height:1.5px;background:rgba(255,255,255,.8);transition:all .22s;}
.nav-mobile{display:none;flex-direction:column;background:var(--black);position:fixed;top:44px;left:0;right:0;z-index:290;border-bottom:1px solid rgba(255,255,255,.1);}
.nav-mobile.open{display:flex;}
.nav-mobile-link{font-size:17px;font-weight:400;letter-spacing:-.374px;color:rgba(255,255,255,.8);text-decoration:none;padding:14px 22px;border-bottom:1px solid rgba(255,255,255,.08);transition:color .15s;}
.nav-mobile-link:hover{color:var(--white);}
.nav-mobile-lang{display:flex;gap:8px;padding:12px 22px;}

/* ─── Footer ─── */
footer{background:var(--parchment);padding:var(--sp-xxl) var(--sp-section);border-top:1px solid var(--hairline);}
.footer-inner{max-width:980px;margin:0 auto;}
.footer-top{display:flex;align-items:flex-start;gap:80px;padding-bottom:var(--sp-xxl);border-bottom:1px solid var(--hairline);margin-bottom:var(--sp-lg);}
.footer-logo img{height:24px;display:block;object-fit:contain;}
.footer-info{display:flex;flex-direction:column;gap:8px;}
.footer-col-title{font-size:14px;font-weight:600;letter-spacing:-.224px;color:var(--ink-48);margin-bottom:12px;}
.footer-nav{display:flex;flex-direction:column;gap:10px;}
.footer-nav a{font-size:14px;font-weight:400;letter-spacing:-.224px;color:var(--ink-80);text-decoration:none;transition:color .15s;}
.footer-nav a:hover{color:var(--blue);}
.footer-row{display:flex;align-items:baseline;gap:12px;}
.footer-key{font-size:14px;font-weight:600;letter-spacing:-.224px;color:var(--ink-48);width:44px;flex-shrink:0;}
.footer-val{font-size:17px;font-weight:400;line-height:2.41;color:var(--ink-80);}
.footer-val a{color:var(--blue);text-decoration:none;}
.footer-val a:hover{text-decoration:underline;}
.footer-bottom{font-size:12px;font-weight:400;color:var(--ink-48);}

/* ─── Hero ─── */
.page-hero{background:#000;padding:72px var(--sp-section) 64px;text-align:center;position:relative;overflow:hidden;}
#hero-canvas{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;}
.page-hero-eyebrow,.page-hero-h1,.page-hero-sub{position:relative;z-index:1;}
.page-hero-eyebrow{display:inline-block;font-size:13px;font-weight:500;letter-spacing:.4px;color:rgba(255,255,255,.9);text-transform:uppercase;margin-bottom:20px;padding:7px 22px;background:rgba(255,255,255,.09);backdrop-filter:blur(20px) saturate(1.4);-webkit-backdrop-filter:blur(20px) saturate(1.4);border:1px solid rgba(255,255,255,.18);border-radius:9999px;box-shadow:inset 0 1px 0 rgba(255,255,255,.22),0 4px 20px rgba(0,0,0,.25);}
.page-hero-h1{font-size:56px;font-weight:600;line-height:1.07;letter-spacing:-.56px;color:var(--white);}
.page-hero-sub{font-size:19px;font-weight:400;line-height:1.42;letter-spacing:-.304px;color:rgba(255,255,255,.56);max-width:520px;margin:14px auto 0;}

/* ─── Hub ─── */
.hub-view{max-width:1240px;margin:0 auto;padding:var(--sp-xxl) var(--sp-section) 100px;}
.hub-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;}
.hub-tile{border-radius:28px;text-decoration:none;color:inherit;overflow:hidden;display:flex;flex-direction:column;transition:transform .35s cubic-bezier(.16,1,.3,1),box-shadow .35s;cursor:pointer;background:#0a0a0a;box-shadow:0 0 0 1px rgba(255,255,255,.11),0 0 0 .5px rgba(160,210,255,.07),0 28px 64px rgba(0,0,0,.7);}
.hub-tile:hover{transform:scale(1.016);box-shadow:0 0 0 1px rgba(255,255,255,.18),0 0 0 .5px rgba(160,210,255,.1),0 36px 80px rgba(0,0,0,.75);}
.hub-tile-visual{aspect-ratio:16/9;position:relative;overflow:hidden;display:flex;align-items:flex-end;}
.hub-tile-visual-bg{position:absolute;inset:0;background:linear-gradient(135deg,#111 0%,#1e1e1e 100%);}
.hub-tile-visual-glow{position:absolute;inset:0;background:radial-gradient(ellipse at 55% 45%,var(--accent) 0%,transparent 62%);opacity:.28;transition:opacity .5s;}
.hub-tile:hover .hub-tile-visual-glow{opacity:.5;}
.hub-tile-visual img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .7s cubic-bezier(.16,1,.3,1),filter .5s;}
.hub-tile:hover .hub-tile-visual img{transform:scale(1.05);filter:brightness(1.08);}
.hub-tile-ray{position:absolute;inset:-70%;background:repeating-conic-gradient(from 0deg at 50% 56%,rgba(255,255,255,.04) 0deg 2.2deg,transparent 2.2deg 19deg);mix-blend-mode:overlay;pointer-events:none;opacity:.7;}
.hub-tile-visual-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.72) 0%,rgba(0,0,0,.1) 55%,transparent 100%);}
/* ── Liquid Glass body panel ── */
.hub-tile-body{padding:24px 32px 32px;background:rgba(6,6,6,.48);backdrop-filter:blur(32px) saturate(1.6);-webkit-backdrop-filter:blur(32px) saturate(1.6);position:relative;}
.hub-tile-body::before{content:'';position:absolute;top:0;left:8%;right:8%;height:1px;background:linear-gradient(90deg,transparent 0%,rgba(255,255,255,.28) 35%,rgba(255,255,255,.45) 50%,rgba(255,255,255,.28) 65%,transparent 100%);}
.hub-eyebrow{font-size:12px;font-weight:500;color:rgba(255,255,255,.5);letter-spacing:.3px;text-transform:uppercase;}
.hub-title{font-size:40px;font-weight:600;letter-spacing:-.5px;color:#fff;margin-top:4px;}
.hub-cta{font-size:16px;color:var(--accent);margin-top:14px;}

/* ─── Category view ─── */
.cat-view{display:none;background:#000;}
.cat-topbar{padding:0 var(--sp-section);height:52px;display:flex;align-items:center;gap:16px;border-bottom:1px solid rgba(255,255,255,.08);position:sticky;top:44px;background:rgba(0,0,0,.7);backdrop-filter:blur(28px) saturate(1.4);-webkit-backdrop-filter:blur(28px) saturate(1.4);z-index:99;}
.cat-back{font-size:15px;color:var(--blue-ondark);text-decoration:none;display:flex;align-items:center;gap:2px;white-space:nowrap;flex-shrink:0;}
.cat-topbar-name{font-size:15px;font-weight:600;color:#fff;}
.cat-search-wrap{position:relative;margin-left:auto;width:220px;}
.cat-search-wrap input{width:100%;height:32px;padding:0 14px 0 32px;font-size:13px;background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.15);border-radius:var(--r-pill);outline:none;transition:background .2s,border-color .2s;}
.cat-search-wrap input::placeholder{color:rgba(255,255,255,.35);}
.cat-search-wrap input:focus{background:rgba(255,255,255,.16);border-color:rgba(255,255,255,.28);}
.cat-search-icon{position:absolute;left:11px;top:50%;transform:translateY(-50%);font-size:12px;color:rgba(255,255,255,.4);pointer-events:none;}
.cat-hero{padding:56px var(--sp-section) 32px;}
.cat-h1{font-size:56px;font-weight:600;letter-spacing:-.6px;color:#fff;}
.cat-sub{font-size:17px;font-weight:400;letter-spacing:-.16px;color:rgba(255,255,255,.55);margin-top:8px;}

/* ─── Product grid ─── */
.sub-band{padding:32px var(--sp-section) 0;font-size:17px;font-weight:600;letter-spacing:-.2px;color:rgba(255,255,255,.55);display:flex;align-items:center;gap:10px;}
.sub-band::after{content:'';flex:1;height:1px;background:rgba(255,255,255,.1);}
.prow-outer{padding:var(--sp-lg) var(--sp-section) var(--sp-xxl);}
.prow{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}

/* ─── Product cards ─── */
.pcard{display:flex;flex-direction:column;text-align:center;background:#111;border-radius:22px;box-shadow:0 0 0 1px rgba(255,255,255,.1),0 20px 48px rgba(0,0,0,.5);overflow:hidden;transition:transform .32s cubic-bezier(.16,1,.3,1),box-shadow .32s;}
.pcard:hover{transform:translateY(-6px) scale(1.016);box-shadow:0 0 0 1px rgba(255,255,255,.2),0 28px 60px rgba(0,0,0,.65);}
.pcard.hidden{display:none;}
.pcard-main-link{display:flex;flex-direction:column;text-decoration:none;color:inherit;flex:1;}
.pcard-main-link *{text-decoration:none;color:inherit;}
.pcard-main-link:visited,.pcard-main-link:visited *{color:inherit;}
.pcard-thumb{aspect-ratio:1;background:#1a1a1a;overflow:hidden;display:flex;align-items:center;justify-content:center;}
.pcard-thumb img{width:72%;height:72%;object-fit:contain;transition:transform .4s cubic-bezier(.16,1,.3,1);}
.pcard-thumb.contain img{width:78%;height:78%;}
.pcard:hover .pcard-thumb img{transform:scale(1.05);}
.pcard-body{padding:14px 12px 4px;}
.pcard-name{font-size:19px;font-weight:600;letter-spacing:-.374px;color:#fff;}
.pcard-cat{font-size:12px;color:rgba(255,255,255,.45);margin-top:4px;letter-spacing:-.08px;}
.pcard-desc{font-size:13px;color:rgba(255,255,255,.45);line-height:1.5;margin-top:6px;}
.pcard-caps{display:flex;flex-wrap:wrap;justify-content:center;gap:4px;margin-top:8px;}
.pcard-cap{font-size:11px;font-weight:500;padding:3px 8px;border-radius:var(--r-pill);background:rgba(255,255,255,.1);color:rgba(255,255,255,.55);}
.pcard-footer{display:flex;justify-content:center;gap:12px;padding:6px 4px 12px;flex-wrap:wrap;}
.pcard-text-link{display:flex;align-items:center;gap:3px;text-decoration:none;}
.pcard-text-link .tl-label{font-size:14px;color:var(--blue-ondark);}
.pcard-text-link .tl-arrow{font-size:12px;color:var(--blue-ondark);}
.pcard-dl-link{display:flex;align-items:center;gap:3px;text-decoration:none;}
.pcard-dl-link .dl-label{font-size:14px;color:var(--blue-ondark);}
.pcard-dl-link .dl-icon{font-size:12px;color:var(--blue-ondark);}
.cat-empty{display:none;text-align:center;padding:80px;font-size:17px;color:rgba(255,255,255,.4);}
.cat-empty.show{display:block;}

/* ─── Responsive ─── */
@media(max-width:1068px){.prow{grid-template-columns:repeat(3,1fr);}footer{padding:var(--sp-xxl) 40px;}}
@media(max-width:834px){.nav-links{display:none;}.nav-burger{display:flex;}.hub-grid{grid-template-columns:1fr;}.hub-view{padding:var(--sp-xxl) 24px 80px;}.hub-tile-body{padding:18px 24px 28px;}.hub-title{font-size:32px;}.prow{grid-template-columns:repeat(2,1fr);}.cat-hero{padding:40px 24px 24px;}.cat-h1{font-size:40px;}.cat-topbar{padding:0 24px;}.sub-band{padding:24px 24px 0;}.prow-outer{padding:var(--sp-md) 24px var(--sp-xxl);}.footer-top{flex-direction:column;gap:32px;}footer{padding:var(--sp-xxl) 32px;}}
@media(max-width:480px){.page-hero{padding:56px 20px 48px;}.page-hero-h1{font-size:38px;}.hub-title{font-size:26px;}.hub-cta{font-size:14px;}.prow{grid-template-columns:1fr 1fr;gap:12px;}.cat-h1{font-size:30px;}.cat-hero{padding:28px 16px 20px;}.cat-topbar{padding:0 16px;}.cat-search-wrap{display:none;}.sub-band{padding:16px 16px 0;font-size:17px;}.prow-outer{padding:12px 16px var(--sp-xl);}footer{padding:var(--sp-xxl) 22px;}}
</style>
</head>
<body>

<nav class="global-nav" id="globalNav">
  <a class="nav-logo" href="index.html">
    <img src="https://pub-03642ec28edd4da6bcaf414c061b4ad6.r2.dev/other/Logo-03.png" alt="Simorchip">
  </a>
  <div class="nav-links">
    <a class="nav-link" href="product.html">Products</a>
    <a class="nav-link" href="solutions.html">Solutions</a>
    <a class="nav-link" href="manufacturing.html">Manufacturing</a>
    <a class="nav-link" href="about.html">About</a>
    <a class="nav-link" href="news/index.html">News</a>
    <a class="nav-link" href="contact.html">Contact</a>
  </div>
  <div class="nav-right">
    <button class="nav-lang-btn active">EN</button>
    <button class="nav-lang-btn">中文</button>
    <button class="nav-burger" id="burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>
<div class="nav-mobile" id="navMobile">
  <a class="nav-mobile-link" href="product.html">Products</a>
  <a class="nav-mobile-link" href="solutions.html">Solutions</a>
  <a class="nav-mobile-link" href="manufacturing.html">Manufacturing</a>
  <a class="nav-mobile-link" href="about.html">About</a>
  <a class="nav-mobile-link" href="news/index.html">News</a>
  <a class="nav-mobile-link" href="contact.html">Contact</a>
  <div class="nav-mobile-lang">
    <button class="nav-lang-btn active">EN</button>
    <button class="nav-lang-btn">中文</button>
  </div>
</div>

<div class="page-hero">
  <canvas id="hero-canvas"></canvas>
  <div class="page-hero-eyebrow">Simorchip</div>
  <h1 class="page-hero-h1">Products.</h1>
  <p class="page-hero-sub">Memory, storage, and graphics solutions built for reliability and performance.</p>
</div>

{% set catGroups = collections.products | groupBy("data.category") %}

<!-- ══ HUB VIEW ══ -->
<div id="hub-view">
  <div class="hub-view">
    <div class="hub-grid">
      {% for catGroup in catGroups %}
        {% set catMeta = productCategories | findWhere("id", catGroup.key) %}
        <a class="hub-tile" href="#{{ catGroup.key }}" style="--accent:{{ catMeta.accent if catMeta else '#888' }}">
          <div class="hub-tile-visual">
            <div class="hub-tile-visual-bg"></div>
            <div class="hub-tile-visual-glow"></div>
            {% if catMeta and catMeta.hub_image %}
            <img src="{{ catMeta.hub_image }}" alt="{{ catMeta.title }}" loading="lazy">
            <div class="hub-tile-ray"></div>
            <div class="hub-tile-visual-overlay"></div>
            {% endif %}
          </div>
          <div class="hub-tile-body">
            <div class="hub-eyebrow">{{ catMeta.label if catMeta else catGroup.key }}</div>
            <div class="hub-title">{{ catMeta.title if catMeta else catGroup.key }}</div>
            <div class="hub-cta">See {{ catGroup.items | length }} products ›</div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

<!-- ══ CATEGORY VIEWS ══ -->
{% for catGroup in catGroups %}
  {% set catMeta = productCategories | findWhere("id", catGroup.key) %}
  {% set bandGroups = catGroup.items | groupBy("data.sub_band") %}
  <div id="cat-{{ catGroup.key }}" class="cat-view">

    <div class="cat-topbar">
      <a class="cat-back" href="#">‹ Products</a>
      <span class="cat-topbar-name">{{ catMeta.title if catMeta else catGroup.key }}</span>
      <div class="cat-search-wrap">
        <span class="cat-search-icon">⌕</span>
        <input type="text" class="cat-search" placeholder="Search…">
      </div>
    </div>

    <div class="cat-hero">
      <h1 class="cat-h1">{{ catMeta.title if catMeta else catGroup.key }}</h1>
      <p class="cat-sub">{{ catMeta.label if catMeta else '' }}</p>
    </div>

    {% for bandGroup in bandGroups %}
      {% if bandGroup.key %}
      <div class="sub-band">{{ bandGroup.key }}</div>
      {% endif %}
      <div class="prow-outer"><div class="prow">
        {% for p in bandGroup.items %}
        <div class="pcard" data-name="{{ p.data.name }}">
          <a class="pcard-main-link" href="{{ p.data.preview_file }}">
            <div class="pcard-thumb{% if p.data.thumb_contain %} contain{% endif %}">
              <img src="{{ p.data.thumbnail }}" alt="{{ p.data.name }}" loading="lazy">
            </div>
            <div class="pcard-body">
              <div class="pcard-name">{{ p.data.name }}</div>
              <div class="pcard-cat">{{ p.data.subtitle }}</div>
              {% if p.data.description %}<div class="pcard-desc">{{ p.data.description }}</div>{% endif %}
              {% if p.data.capacities and p.data.capacities | length %}
              <div class="pcard-caps">{% for cap in p.data.capacities %}<span class="pcard-cap">{{ cap }}</span>{% endfor %}</div>
              {% endif %}
            </div>
          </a>
          {% if p.data.text_file or p.data.datasheet %}
          <div class="pcard-footer">
            {% if p.data.text_file %}<a class="pcard-text-link" href="{{ p.data.text_file }}"><span class="tl-label">Copywriting</span><span class="tl-arrow">↗</span></a>{% endif %}
            {% if p.data.datasheet %}<a class="pcard-dl-link" href="{{ p.data.datasheet }}" download><span class="dl-label">Datasheet</span><span class="dl-icon">↓</span></a>{% endif %}
          </div>
          {% endif %}
        </div>
        {% endfor %}
      </div></div>
    {% endfor %}

    <div class="cat-empty">No products match your search.</div>
  </div>
{% endfor %}

<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-logo">
        <img src="https://pub-03642ec28edd4da6bcaf414c061b4ad6.r2.dev/other/Logo-04.png" alt="Simorchip">
      </div>
      <nav class="footer-nav">
        <div class="footer-col-title">Sitemap</div>
        <a href="product.html">Products</a>
        <a href="solutions.html">Solutions</a>
        <a href="manufacturing.html">Manufacturing</a>
        <a href="about.html">About</a>
        <a href="news/index.html">News</a>
        <a href="contact.html">Contact</a>
      </nav>
      <div class="footer-info">
        <div class="footer-row"><span class="footer-key">TEL</span><span class="footer-val">+886-2-2657-6680</span></div>
        <div class="footer-row"><span class="footer-key">EMAIL</span><span class="footer-val"><a href="mailto:sales@simorchip.com">sales@simorchip.com</a></span></div>
        <div class="footer-row"><span class="footer-key">ADD</span><span class="footer-val">8F.-1, No. 300, Sec. 1, Neihu Rd., Neihu Dist., Taipei City 114066, Taiwan</span></div>
      </div>
    </div>
    <div class="footer-bottom">Copyright © 2026 – Simorchip. All rights reserved. Design by Simorchip</div>
  </div>
</footer>

<script>
(function(){
  const canvas=document.getElementById('hero-canvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const hero=canvas.parentElement;
  const COLORS=['#c8200e','#c8922a','#76b900','#0d9488'];
  let W,H;
  function resize(){W=canvas.width=hero.offsetWidth;H=canvas.height=hero.offsetHeight;}
  resize();
  window.addEventListener('resize',resize);

  const N=60;
  const pts=Array.from({length:N},()=>({
    x:Math.random(),y:Math.random(),
    vx:(Math.random()-.5)*.00035,vy:(Math.random()-.5)*.00035,
    r:Math.random()*1.8+.6,
    col:COLORS[Math.floor(Math.random()*4)],
    pulse:Math.random()*Math.PI*2,
  }));

  const MAX=.22;

  function tick(){
    ctx.clearRect(0,0,W,H);
    const t=performance.now()/1000;

    for(let i=0;i<N;i++){
      for(let j=i+1;j<N;j++){
        const dx=(pts[i].x-pts[j].x)*W,dy=(pts[i].y-pts[j].y)*H;
        const d=Math.sqrt(dx*dx+dy*dy)/(W*MAX);
        if(d<1){
          ctx.beginPath();
          ctx.moveTo(pts[i].x*W,pts[i].y*H);
          ctx.lineTo(pts[j].x*W,pts[j].y*H);
          ctx.strokeStyle=pts[i].col;
          ctx.globalAlpha=(1-d)*.4;
          ctx.lineWidth=.7;
          ctx.stroke();
        }
      }
    }

    pts.forEach(p=>{
      const glow=Math.sin(t*1.2+p.pulse)*.4+.7;
      ctx.save();
      ctx.globalAlpha=glow*.95;
      ctx.shadowColor=p.col;
      ctx.shadowBlur=12*glow;
      ctx.beginPath();
      ctx.arc(p.x*W,p.y*H,p.r*(glow*.3+.8),0,Math.PI*2);
      ctx.fillStyle=p.col;
      ctx.fill();
      ctx.restore();

      p.x+=p.vx; p.y+=p.vy;
      if(p.x<0)p.x=1; if(p.x>1)p.x=0;
      if(p.y<0)p.y=1; if(p.y>1)p.y=0;
    });

    ctx.globalAlpha=1;
    requestAnimationFrame(tick);
  }
  tick();
})();
</script>
<script>
const burger=document.getElementById('burger');
const navMobile=document.getElementById('navMobile');
if(burger&&navMobile){
  burger.addEventListener('click',()=>{
    navMobile.classList.toggle('open');
    const sp=burger.querySelectorAll('span');
    if(navMobile.classList.contains('open')){sp[0].style.transform='rotate(45deg) translate(4px,4px)';sp[1].style.opacity='0';sp[2].style.transform='rotate(-45deg) translate(4px,-4px)';}
    else{sp.forEach(s=>{s.style.transform='';s.style.opacity='';});}
  });
  navMobile.querySelectorAll('.nav-mobile-link').forEach(l=>{l.addEventListener('click',()=>{navMobile.classList.remove('open');burger.querySelectorAll('span').forEach(s=>{s.style.transform='';s.style.opacity='';});});});
}
</script>

<script>
const hubEl = document.getElementById('hub-view');
const catViews = document.querySelectorAll('.cat-view');

function showView(hash) {
  const cat = (hash || '').replace('#', '');
  if (cat) {
    const target = document.getElementById('cat-' + cat);
    if (target) {
      hubEl.style.display = 'none';
      catViews.forEach(v => v.style.display = 'none');
      target.style.display = 'block';
      window.scrollTo({ top: 0, behavior: 'instant' });
      return;
    }
  }
  hubEl.style.display = '';
  catViews.forEach(v => v.style.display = 'none');
  window.scrollTo({ top: 0, behavior: 'instant' });
}

showView(location.hash);
window.addEventListener('popstate', () => showView(location.hash));

document.querySelectorAll('.hub-tile').forEach(tile => {
  tile.addEventListener('click', e => {
    e.preventDefault();
    const hash = tile.getAttribute('href');
    history.pushState(null, '', hash);
    showView(hash);
  });
});

document.querySelectorAll('.cat-back').forEach(btn => {
  btn.addEventListener('click', e => {
    e.preventDefault();
    history.pushState(null, '', location.pathname);
    showView('');
  });
});

document.querySelectorAll('.cat-search').forEach(input => {
  input.addEventListener('input', () => {
    const catView = input.closest('.cat-view');
    const q = input.value.toLowerCase().trim();
    const cards = catView.querySelectorAll('.pcard');
    let shown = 0;
    cards.forEach(c => {
      const name = (c.dataset.name || '').toLowerCase();
      const ok = !q || name.includes(q);
      c.classList.toggle('hidden', !ok);
      if (ok) shown++;
    });
    catView.querySelectorAll('.prow-outer').forEach(row => {
      const vis = Array.from(row.querySelectorAll('.pcard')).some(c => !c.classList.contains('hidden'));
      row.style.display = vis ? '' : 'none';
      const prev = row.previousElementSibling;
      if (prev && prev.classList.contains('sub-band')) prev.style.display = vis ? '' : 'none';
    });
    const emptyEl = catView.querySelector('.cat-empty');
    if (emptyEl) emptyEl.classList.toggle('show', shown === 0);
  });
});
</script>
</body>
</html>
