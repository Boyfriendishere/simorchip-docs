<script>
// Scroll fade-in
const fadeEls = document.querySelectorAll('.fade-in');
if(fadeEls.length){
  const io = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){ e.target.classList.add('visible'); io.unobserve(e.target); }
    });
  },{threshold:0.12});
  fadeEls.forEach(el=>io.observe(el));
}
</script>

<script>
// Marquee — duplicate track content for seamless loop
const marqueeTrack = document.getElementById('marqueeTrack');
if(marqueeTrack){ marqueeTrack.innerHTML += marqueeTrack.innerHTML; }

// Scroll progress bar
const progressBar = document.getElementById('scrollProgress');
const toTop = document.getElementById('toTop');
let ticking = false;
window.addEventListener('scroll',()=>{
  if(ticking) return;
  ticking = true;
  requestAnimationFrame(()=>{
    const max = document.documentElement.scrollHeight - innerHeight;
    if(progressBar) progressBar.style.width = (max > 0 ? (scrollY / max) * 100 : 0) + '%';
    if(toTop) toTop.classList.toggle('show', scrollY > innerHeight * 0.8);
    // Hero parallax — content drifts up and fades as you scroll past
    const heroContent = document.querySelector('.hero-tile-content');
    if(heroContent && scrollY < innerHeight){
      heroContent.style.transform = 'translateY(' + scrollY * 0.18 + 'px)';
      heroContent.style.opacity = 1 - (scrollY / innerHeight) * 1.2;
    }
    ticking = false;
  });
},{passive:true});
if(toTop) toTop.addEventListener('click',()=>scrollTo({top:0,behavior:'smooth'}));

// Stats count-up
const counters = document.querySelectorAll('.count-up');
if(counters.length){
  const fmt = n => n >= 1000 ? n.toLocaleString('en-US') : String(n);
  const cio = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(!e.isIntersecting) return;
      cio.unobserve(e.target);
      const target = parseInt(e.target.dataset.count,10);
      const dur = 1400, t0 = performance.now();
      const step = now=>{
        const p = Math.min((now - t0) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        e.target.textContent = fmt(Math.round(target * eased));
        if(p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    });
  },{threshold:0.5});
  counters.forEach(el=>cio.observe(el));
}

// Feature card spotlight — radial glow follows the cursor
document.querySelectorAll('.feature-card').forEach(card=>{
  card.addEventListener('pointermove',ev=>{
    const r = card.getBoundingClientRect();
    card.style.setProperty('--mx',(ev.clientX - r.left) + 'px');
    card.style.setProperty('--my',(ev.clientY - r.top) + 'px');
  });
});

// Image curtain reveal — opens only after the image has actually loaded
const revealEls = document.querySelectorAll('.img-reveal');
if(revealEls.length){
  const reveal = el=>el.classList.add('visible');
  const rio = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(!e.isIntersecting) return;
      rio.unobserve(e.target);
      const img = e.target.querySelector('img');
      if(img && !img.complete){
        img.addEventListener('load',()=>reveal(e.target),{once:true});
        img.addEventListener('error',()=>reveal(e.target),{once:true});
        setTimeout(()=>reveal(e.target),4000);
      } else {
        reveal(e.target);
      }
    });
  },{threshold:0.2});
  revealEls.forEach(el=>rio.observe(el));
  // Fallback — if the observer never fires (e.g. blocked in some browsers), reveal anyway
  window.addEventListener('load',()=>setTimeout(()=>revealEls.forEach(reveal),1500));
}

// Magnetic hero CTA buttons
document.querySelectorAll('.hero-cta .btn-pill').forEach(btn=>{
  btn.addEventListener('pointermove',ev=>{
    const r = btn.getBoundingClientRect();
    const dx = (ev.clientX - r.left - r.width / 2) * 0.18;
    const dy = (ev.clientY - r.top - r.height / 2) * 0.3;
    btn.style.transform = 'translate(' + dx + 'px,' + dy + 'px)';
  });
  btn.addEventListener('pointerleave',()=>{ btn.style.transform = ''; });
});

// Dot-matrix world map — lights up radiating outward from Taipei HQ
const mapGrid = [
"................................................................",
"..............#####.....####....................................",
"............########....#####........#..################........",
"...####...##########.....####......##.#######################...",
"..###################....###.#....############################..",
".####################.........#...#############################.",
"........##############.......##.###############################.",
".........#############........##############################....",
"..........###########........#########.################.##......",
"..........##########.........#######.#######..#########.##......",
"...........#######..........##############.############.........",
"............####............############...############.........",
".............####...........########.##....####..####.##........",
"...............###..........#######...##....##...####.##........",
"................######........#########......#...##.###.........",
".................#######.......########.........###.##.#.###....",
"..................########......#######..........##.##..####....",
"..................########......#######..........###.....##.....",
"...................#######......#######.............######......",
"...................######.......######.#...........########.....",
"...................#####........#####..#...........########.....",
"...................####.........####...............#######....#.",
"...................####..........##.................####.....##.",
"...................###..................................#...##..",
"...................###..........................................",
"...................##..........................................."
];
const dotMapSvg = document.getElementById('dotMap');
const mapWrap = document.getElementById('mapWrap');
if(dotMapSvg && mapWrap){
  const HQ = {c:53.6,r:11.6};
  const ns = 'http://www.w3.org/2000/svg';
  mapGrid.forEach((rowStr,r)=>{
    for(let c=0;c<rowStr.length;c++){
      if(rowStr[c] !== '#') continue;
      const dot = document.createElementNS(ns,'circle');
      dot.setAttribute('cx',c*10+5);
      dot.setAttribute('cy',r*10+5);
      dot.setAttribute('r',3);
      dot.setAttribute('class','map-dot');
      dot.style.transitionDelay = Math.round(Math.hypot(c-HQ.c,r-HQ.r)*22) + 'ms';
      dotMapSvg.appendChild(dot);
    }
  });
  const mio = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){ mapWrap.classList.add('lit'); mio.unobserve(e.target); }
    });
  },{threshold:0.3});
  mio.observe(mapWrap);
}

// Scroll hint fades once the user starts scrolling
const scrollHint = document.querySelector('.scroll-hint');
if(scrollHint){
  window.addEventListener('scroll',()=>{
    scrollHint.style.opacity = scrollY > 60 ? '0' : '';
  },{passive:true});
}
</script>

