      <span class="pill-tag">{{ home.pillTag }}</span>
      <span>{{ home.pillText }}</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="hero-h1">
      <span class="line"><span>{{ home.headline }} <span class="grad">{{ home.headlineGradWord }}</span></span></span>
    </h1>
    <div class="hero-cta">
      <a class="btn-pill btn-blue" href="{{ home.cta1Url }}">{{ home.cta1Text }}</a>
      <a class="btn-pill btn-ghost-dark" href="{{ home.cta2Url }}">{{ home.cta2Text }}</a>
    </div>
  </div>
  <div class="scroll-hint">
    <div class="chev"></div>
    <div class="chev"></div>
  </div>
</div>

<!-- ══ NEWS TILE — light ══ -->
{% if collections.news.length %}
<div class="tile tile-light">
  <div class="tile-inner">
    <div class="tile-eyebrow fade-in">Latest Updates</div>
    <h2 class="tile-h2 fade-in fade-in-delay-1">News.</h2>
    <div class="news-grid">
      {% for post in collections.news %}
      {% if loop.index <= 3 %}
      <a class="news-tile-card fade-in fade-in-delay-{{ loop.index }}" href="{{ post.url }}">
        {% if post.data.cover %}<img class="news-tile-cover" src="{{ post.data.cover }}" alt="{{ post.data.title }}" loading="lazy">{% else %}<div class="news-tile-cover news-tile-cover-empty"></div>{% endif %}
        <div class="news-tile-date">{{ post.data.date | dateDisplay }}</div>
        <div class="news-tile-title">{{ post.data.title }}</div>
        <div class="news-tile-excerpt">{{ post.data.excerpt }}</div>
      </a>
      {% endif %}
      {% endfor %}
    </div>
    <div class="tile-cta fade-in fade-in-delay-3" style="margin-top:var(--sp-xl);">
      <a class="text-link" href="/news/">View All News</a>
    </div>
  </div>
</div>
{% endif %}

<!-- ══ MARQUEE BAND ══ -->
<div class="marquee-band" aria-hidden="true">
  <div class="marquee-track" id="marqueeTrack">
    <span class="marquee-item">SSD</span><span class="marquee-dot"></span>
    <span class="marquee-item">DDR5 DRAM</span><span class="marquee-dot"></span>
