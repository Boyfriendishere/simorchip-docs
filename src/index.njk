<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simorchip — Storage &amp; Memory Solutions</title>
<meta name="description" content="Simorchip delivers SSD, DRAM, GPU, and external storage solutions for consumer, commercial, and channel markets — engineered for performance, validated for reliability.">
<meta name="theme-color" content="#000000">
<meta property="og:title" content="Simorchip — Storage &amp; Memory Solutions">
<meta property="og:description" content="SSD, DRAM, GPU, and external storage solutions — engineered for performance, validated for reliability.">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<style>
/* ══ DESIGN TOKENS — Apple-design-analysis adapted for Simorchip ══ */
:root{
  --blue:#0066cc;
  --blue-dark:#0071e3;
  --blue-ondark:#2997ff;
  --ink:#1d1d1f;
  --ink-80:#333333;
  --ink-48:#7a7a7a;
  --muted-dark:#cccccc;
  --white:#ffffff;
  --canvas:#ffffff;
  --parchment:#f5f5f7;
  --pearl:#fafafc;
  --tile-1:#272729;
  --tile-2:#2a2a2c;
  --tile-3:#252527;
  --black:#000000;
  --hairline:#e0e0e0;
  --divider-soft:#f0f0f0;
  --sp-xs:8px; --sp-sm:12px; --sp-md:17px; --sp-lg:24px;
  --sp-xl:32px; --sp-xxl:48px; --sp-section:80px;
  --f:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
  --r-sm:8px; --r-lg:18px; --r-pill:9999px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:var(--f);background:var(--canvas);color:var(--ink);-webkit-font-smoothing:antialiased;padding-top:44px;}

/* ══ GLOBAL NAV ══ */
.global-nav{
  position:fixed;top:0;left:0;right:0;z-index:300;
  background:rgba(0,0,0,.8);
  -webkit-backdrop-filter:saturate(180%) blur(20px);
  backdrop-filter:saturate(180%) blur(20px);
  height:44px;
  display:grid;grid-template-columns:1fr auto 1fr;align-items:center;
  padding:0 22px;
}
.nav-logo{grid-column:1;justify-self:start;}
.nav-logo img{height:20px;display:block;filter:brightness(0) invert(1);opacity:.85;}
.nav-links{display:flex;align-items:center;gap:20px;grid-column:2;justify-self:center;}
.nav-link{
  position:relative;
  font-size:12px;font-weight:400;letter-spacing:-.12px;line-height:1;
  color:rgba(255,255,255,.8);text-decoration:none;
  padding-bottom:4px;
  transition:color .25s ease;white-space:nowrap;
}
.nav-link::after{
  content:'';position:absolute;left:0;right:100%;bottom:-2px;height:1px;
  background:var(--blue-ondark);transition:right .3s cubic-bezier(.16,1,.3,1);
}
.nav-link:hover{color:var(--white);}
.nav-link:hover::after{right:0;}
.nav-right{display:flex;align-items:center;gap:8px;grid-column:3;justify-self:end;}
.nav-lang-btn{
  font-size:12px;font-weight:400;letter-spacing:-.12px;
  color:rgba(255,255,255,.5);background:none;border:none;cursor:pointer;
  padding:4px 8px;border-radius:var(--r-sm);transition:color .15s;
}
.nav-lang-btn:hover{color:var(--white);}
.nav-lang-btn.active{color:var(--white);}
.nav-burger{
  display:none;flex-direction:column;gap:4px;
  background:none;border:none;cursor:pointer;padding:6px 4px;
}
.nav-burger span{display:block;width:18px;height:1.5px;background:rgba(255,255,255,.8);transition:all .22s;}
.nav-mobile{
  display:none;flex-direction:column;
  background:var(--black);
  position:fixed;top:44px;left:0;right:0;z-index:290;
  border-bottom:1px solid rgba(255,255,255,.1);
}
.nav-mobile.open{display:flex;}
.nav-mobile-link{
  font-size:17px;font-weight:400;letter-spacing:-.374px;line-height:1.47;
  color:rgba(255,255,255,.8);text-decoration:none;
  padding:14px 22px;border-bottom:1px solid rgba(255,255,255,.08);
  transition:color .15s;
}
.nav-mobile-link:hover{color:var(--white);}
.nav-mobile-lang{display:flex;gap:8px;padding:12px 22px;}

/* ══ HERO TILE (full-bleed video, dark) ══ */
.hero-tile{
  position:relative;width:100%;height:100vh;min-height:600px;
  background:var(--black);overflow:hidden;
  margin-top:-44px;
}
.hero-tile video{
  position:absolute;inset:0;width:100%;height:100%;
  object-fit:cover;pointer-events:none;opacity:.7;
  animation:heroZoom 24s ease-in-out infinite alternate;
}
@keyframes heroZoom{from{transform:scale(1);}to{transform:scale(1.07);}}
.hero-tile-floor{
  position:absolute;bottom:0;left:0;right:0;height:60%;
  background:linear-gradient(to top,rgba(0,0,0,.75) 0%,transparent 100%);
  pointer-events:none;
}
.hero-tile-content{
  position:absolute;bottom:var(--sp-section);left:0;right:0;
  text-align:center;padding:0 var(--sp-section);
}
.hero-kicker{
  font-size:12px;font-weight:400;letter-spacing:-.12px;
  color:var(--muted-dark);margin-bottom:var(--sp-sm);
}
.hero-h1{
  font-size:68px;font-weight:600;line-height:1.07;letter-spacing:-.8px;
  color:var(--white);margin-bottom:var(--sp-md);
}
.hero-sub{
  font-size:28px;font-weight:400;line-height:1.14;letter-spacing:.196px;
  color:var(--muted-dark);margin-bottom:var(--sp-xl);
}
.hero-cta{display:flex;gap:var(--sp-sm);justify-content:center;flex-wrap:wrap;}
.btn-pill{
  position:relative;overflow:hidden;
  font-size:17px;font-weight:400;letter-spacing:-.374px;line-height:1;
  padding:11px 22px;border-radius:var(--r-pill);
  text-decoration:none;display:inline-block;
  transition:transform .25s cubic-bezier(.16,1,.3,1),background-color .25s ease,box-shadow .25s ease,border-color .25s ease;
  cursor:pointer;border:1px solid transparent;
}
.btn-blue::after{
  content:'';position:absolute;top:0;left:-90%;width:55%;height:100%;
  background:linear-gradient(105deg,transparent,rgba(255,255,255,.35),transparent);
  transform:skewX(-20deg);pointer-events:none;
}
.btn-blue:hover::after{left:140%;transition:left .65s ease;}
.btn-pill:active{transform:scale(.96);}
.btn-blue{background:var(--blue);color:var(--white);}
.btn-blue:hover{background:var(--blue-dark);box-shadow:0 8px 20px rgba(0,102,204,.28);transform:translateY(-2px);}
.btn-ghost-dark{
  background:transparent;color:var(--blue-ondark);
  border:1px solid var(--blue-ondark);
}
.btn-ghost-dark:hover{background:rgba(41,151,255,.1);border-color:var(--white);color:var(--white);transform:translateY(-2px);}
.scroll-hint{
  position:absolute;bottom:18px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:5px;pointer-events:none;
}
.scroll-hint .chev{
  width:16px;height:16px;
  border-right:1.5px solid rgba(255,255,255,.3);
  border-bottom:1.5px solid rgba(255,255,255,.3);
  transform:rotate(45deg);
  animation:chevAnim 1.7s ease-in-out infinite;
}
.scroll-hint .chev:nth-child(2){margin-top:-11px;opacity:.2;animation-delay:.22s;}
@keyframes chevAnim{
  0%,100%{transform:rotate(45deg) translateY(0);opacity:.3;}
  50%{transform:rotate(45deg) translateY(5px);opacity:.9;}
}

/* ══ PRODUCT TILES ══ */
.tile{width:100%;padding:var(--sp-section) var(--sp-section);text-align:center;}
.tile-light{background:var(--canvas);color:var(--ink);}
.tile-parchment{background:var(--parchment);color:var(--ink);}
.tile-dark{background:var(--tile-1);color:var(--white);}
.tile-dark-2{background:var(--tile-2);color:var(--white);}
.tile-inner{max-width:980px;margin:0 auto;}
.tile-eyebrow{
  font-size:21px;font-weight:600;line-height:1.19;letter-spacing:.231px;
  margin-bottom:8px;
}
.tile-light .tile-eyebrow{color:var(--ink-48);}
.tile-dark .tile-eyebrow,.tile-dark-2 .tile-eyebrow{color:var(--muted-dark);}
.tile-parchment .tile-eyebrow{color:var(--ink-48);}
.tile-h2{
  font-size:40px;font-weight:600;line-height:1.1;letter-spacing:0;
  margin-bottom:var(--sp-md);
}
.tile-light .tile-h2,.tile-parchment .tile-h2{color:var(--ink);}
.tile-dark .tile-h2,.tile-dark-2 .tile-h2{color:var(--white);}
.tile-lead{
  font-size:28px;font-weight:400;line-height:1.14;letter-spacing:.196px;
  margin-bottom:var(--sp-xl);max-width:640px;margin-left:auto;margin-right:auto;
}
.tile-light .tile-lead,.tile-parchment .tile-lead{color:var(--ink);}
.tile-dark .tile-lead,.tile-dark-2 .tile-lead{color:var(--muted-dark);}
.tile-body{
  font-size:17px;font-weight:400;line-height:1.47;letter-spacing:-.374px;
  max-width:640px;margin:0 auto var(--sp-xl);
}
.tile-light .tile-body,.tile-parchment .tile-body{color:var(--ink);}
.tile-dark .tile-body,.tile-dark-2 .tile-body{color:var(--muted-dark);}
.tile-cta{display:flex;gap:var(--sp-sm);justify-content:center;flex-wrap:wrap;}
.btn-ghost-light{
  background:transparent;color:var(--blue);
  border:1px solid var(--blue);
  font-size:17px;font-weight:400;letter-spacing:-.374px;line-height:1;
  padding:11px 22px;border-radius:var(--r-pill);
  text-decoration:none;display:inline-block;
  transition:transform .25s cubic-bezier(.16,1,.3,1),background-color .25s ease,box-shadow .25s ease,border-color .25s ease;
}
.btn-ghost-light:hover{background:rgba(0,102,204,.06);border-color:var(--blue-dark);box-shadow:0 8px 20px rgba(0,102,204,.12);transform:translateY(-2px);}
.btn-ghost-light:active{transform:scale(.96);}
.text-link{
  position:relative;
  font-size:17px;font-weight:400;letter-spacing:-.374px;line-height:1.47;
  color:var(--blue);text-decoration:none;
  display:inline-flex;align-items:center;gap:4px;
}
.text-link::after{content:'›';font-size:20px;line-height:1;transition:transform .25s cubic-bezier(.16,1,.3,1);}
.text-link::before{
  content:'';position:absolute;left:0;right:100%;bottom:-1px;height:1px;
  background:currentColor;transition:right .3s cubic-bezier(.16,1,.3,1);
}
.text-link:hover::before{right:0;}
.text-link:hover::after{transform:translateX(3px);}
.text-link-dark{color:var(--blue-ondark);}

/* ══ STATS TILE ══ */
.stats-grid{
  display:grid;grid-template-columns:repeat(5,1fr);
  gap:1px;background:var(--hairline);
  margin-top:var(--sp-xxl);text-align:center;
}
.stat-cell{background:var(--parchment);padding:var(--sp-xl) var(--sp-lg);}
.stat-num{
  font-size:40px;font-weight:600;line-height:1.1;
  color:var(--ink);letter-spacing:0;margin-bottom:8px;
}
.stat-num sup{font-size:20px;color:var(--blue);vertical-align:super;}
.stat-desc{
  font-size:14px;font-weight:400;line-height:1.43;letter-spacing:-.224px;
  color:var(--ink-48);
}

/* ══ FEATURE GRID ══ */
.feature-grid{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:var(--sp-lg);margin-top:var(--sp-xxl);text-align:left;
}
.feature-card{
  position:relative;
  background:var(--canvas);
  border:1px solid var(--hairline);
  border-radius:var(--r-lg);
  padding:var(--sp-lg);overflow:hidden;
  transition:transform .35s cubic-bezier(.16,1,.3,1),box-shadow .35s cubic-bezier(.16,1,.3,1),border-color .35s ease;
}
.feature-card::before{
  content:'';position:absolute;top:0;left:0;bottom:0;width:3px;
  background:var(--blue);transform:scaleY(0);transform-origin:bottom;
  transition:transform .35s cubic-bezier(.16,1,.3,1);
}
.feature-card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.08);border-color:rgba(0,102,204,.2);}
.feature-card:hover::before{transform:scaleY(1);}
.feature-card-title{
  font-size:17px;font-weight:600;line-height:1.24;letter-spacing:-.374px;
  color:var(--ink);margin-bottom:8px;
}
.feature-card-body{
  font-size:14px;font-weight:400;line-height:1.43;letter-spacing:-.224px;
  color:var(--ink-48);
}

/* ══ NEWS GRID ══ */
.news-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:var(--sp-lg);margin-top:var(--sp-xxl);text-align:left;
}
.news-tile-card{
  display:block;text-decoration:none;color:inherit;
  background:var(--canvas);
  border:1px solid var(--hairline);
  border-radius:var(--r-lg);overflow:hidden;
  transition:transform .35s cubic-bezier(.16,1,.3,1),box-shadow .35s cubic-bezier(.16,1,.3,1),border-color .35s ease;
}
.news-tile-card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.08);border-color:rgba(0,102,204,.2);}
.news-tile-cover{width:100%;aspect-ratio:16/9;object-fit:cover;display:block;background:var(--parchment);}
.news-tile-cover-empty{background:linear-gradient(135deg,var(--parchment),var(--hairline));}
.news-tile-date{
  font-size:13px;font-weight:400;letter-spacing:-.12px;
  color:var(--ink-48);padding:var(--sp-lg) var(--sp-lg) 0;
}
.news-tile-title{
  font-size:17px;font-weight:600;line-height:1.3;letter-spacing:-.374px;
  color:var(--ink);padding:6px var(--sp-lg) 0;
  transition:color .25s ease;
}
.news-tile-excerpt{
  font-size:14px;font-weight:400;line-height:1.43;letter-spacing:-.224px;
  color:var(--ink-48);padding:6px var(--sp-lg) var(--sp-lg);
}
.news-tile-card:hover .news-tile-title{color:var(--blue);}

/* ══ MFG LIST ══ */
.mfg-list{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1px;background:rgba(255,255,255,.10);
  margin-top:var(--sp-xxl);text-align:left;
  border-radius:var(--r-lg);overflow:hidden;
}
.mfg-item{background:var(--tile-1);padding:var(--sp-xl) var(--sp-lg);transition:background .35s cubic-bezier(.16,1,.3,1);}
.mfg-item:hover{background:var(--tile-2);}
.mfg-item-num{
  font-size:12px;font-weight:400;letter-spacing:-.12px;
  color:var(--blue-ondark);margin-bottom:var(--sp-sm);
}
.mfg-item-title{
  font-size:21px;font-weight:600;line-height:1.19;letter-spacing:.231px;
  color:var(--white);
}
.mfg-item-body{
  font-size:14px;font-weight:400;line-height:1.43;letter-spacing:-.224px;
  color:var(--muted-dark);margin-top:8px;
}

/* ══ FOOTER ══ */
footer{
  background:var(--parchment);
  padding:var(--sp-xxl) var(--sp-section);
  border-top:1px solid var(--hairline);
}
.footer-inner{max-width:980px;margin:0 auto;}
.footer-top{
  display:flex;align-items:flex-start;gap:80px;
  padding-bottom:var(--sp-xxl);
  border-bottom:1px solid var(--hairline);
  margin-bottom:var(--sp-lg);
}
.footer-logo img{height:24px;display:block;object-fit:contain;}
.footer-info{display:flex;flex-direction:column;gap:8px;}
.footer-col-title{
  font-size:14px;font-weight:600;letter-spacing:-.224px;line-height:1.29;
  color:var(--ink-48);margin-bottom:12px;
}
.footer-nav{display:flex;flex-direction:column;gap:10px;}
.footer-nav a{
  font-size:14px;font-weight:400;line-height:1.43;letter-spacing:-.224px;
  color:var(--ink-80);text-decoration:none;transition:color .15s;
}
.footer-nav a:hover{color:var(--blue);}
.footer-row{display:flex;align-items:baseline;gap:12px;}
.footer-key{
  font-size:14px;font-weight:600;letter-spacing:-.224px;line-height:1.29;
  color:var(--ink-48);width:44px;flex-shrink:0;
}
.footer-val{
  font-size:17px;font-weight:400;line-height:2.41;letter-spacing:0;
  color:var(--ink-80);
}
.footer-val a{color:var(--blue);text-decoration:none;}
.footer-val a:hover{text-decoration:underline;}
.footer-bottom{
  font-size:12px;font-weight:400;line-height:1;letter-spacing:-.12px;
  color:var(--ink-48);
}

/* ══ RWD ══ */
@media(max-width:1068px){
  .hero-h1{font-size:48px;}
  .tile{padding:var(--sp-section) 40px;}
  .stats-grid{grid-template-columns:repeat(3,1fr);}
  .feature-grid{grid-template-columns:1fr 1fr;}
  .news-grid{grid-template-columns:1fr 1fr;}
  .mfg-list{grid-template-columns:1fr 1fr;}
  footer{padding:var(--sp-xxl) 40px;}
}
@media(max-width:834px){
  .nav-links{display:none;}
  .nav-burger{display:flex;}
  .hero-tile-content{padding:0 32px;bottom:56px;}
  .hero-h1{font-size:34px;}
  .hero-sub{font-size:21px;}
  .tile{padding:var(--sp-section) 32px;}
  .tile-h2{font-size:32px;}
  .tile-lead{font-size:21px;}
  .stats-grid{grid-template-columns:1fr 1fr;}
  .mfg-list{grid-template-columns:1fr;}
  .footer-top{flex-direction:column;gap:32px;}
  footer{padding:var(--sp-xxl) 32px;}
}
@media(max-width:640px){
  .hero-h1{font-size:28px;}
  .hero-sub{font-size:17px;}
  .tile{padding:64px 22px;}
  .tile-h2{font-size:28px;}
  .feature-grid{grid-template-columns:1fr;}
  .news-grid{grid-template-columns:1fr;}
  .stats-grid{grid-template-columns:1fr;}
  .mfg-list{grid-template-columns:1fr;}
  footer{padding:var(--sp-xxl) 22px;}
}

/* ══ SPLIT TILE ══ */
.tile-split{padding:0;text-align:left;}
.tile-split-inner{display:grid;grid-template-columns:1fr 1fr;min-height:600px;max-width:100%;}
.tile-split-reverse{direction:ltr;}
.tile-split-reverse .tile-split-text{order:1;}
.tile-split-reverse .tile-split-photo{order:2;}
.tile-split-photo{overflow:hidden;position:relative;}
.tile-split-photo img{
  width:100%;height:100%;object-fit:cover;object-position:center;display:block;
  transition:transform .6s ease;
}
.tile-split:hover .tile-split-photo img{transform:scale(1.03);}
.tile-split-text{padding:80px 64px;display:flex;flex-direction:column;justify-content:center;}
.tile-split-text .tile-eyebrow{text-align:left;}
.tile-split-text .tile-h2{text-align:left;margin-bottom:16px;}
.tile-split-text .tile-lead{text-align:left;margin-left:0;margin-right:0;font-size:24px;margin-bottom:24px;}
.tile-split-text .tile-body{text-align:left;margin-left:0;margin-right:0;margin-bottom:32px;}
@media(max-width:1024px){.tile-split-text{padding:64px 48px;}}
@media(max-width:768px){
  .tile-split-inner{grid-template-columns:1fr;min-height:auto;}
  .tile-split-reverse{direction:ltr;}
  .tile-split-photo{height:300px;order:-1;}
  .tile-split-text{padding:48px 32px;}
  .tile-split-text .tile-lead{font-size:21px;}
}
@media(max-width:480px){
  .tile-split-photo{height:240px;}
  .tile-split-text{padding:36px 20px;}
}

/* ══ PRE-FOOTER CTA BAND ══ */
.cta-band{
  background:var(--tile-1);
  padding:var(--sp-section) var(--sp-section);
  text-align:center;border-top:1px solid rgba(255,255,255,.06);
}
.cta-band-inner{max-width:640px;margin:0 auto;}
.cta-band-label{
  font-size:21px;font-weight:600;line-height:1.19;letter-spacing:.231px;
  color:var(--blue-ondark);margin-bottom:16px;
}
.cta-band-h2{
  font-size:40px;font-weight:600;line-height:1.1;letter-spacing:0;
  color:var(--white);margin-bottom:var(--sp-xl);
}
.cta-band-actions{display:flex;gap:var(--sp-sm);justify-content:center;flex-wrap:wrap;}
@media(max-width:640px){.cta-band{padding:64px 22px;}.cta-band-h2{font-size:28px;}}

/* ══ SCROLL FADE-IN ══ */
.fade-in{opacity:0;transform:translateY(24px);transition:opacity .6s ease, transform .6s ease;}
.fade-in.visible{opacity:1;transform:translateY(0);}
.fade-in-delay-1{transition-delay:.1s;}
.fade-in-delay-2{transition-delay:.2s;}
.fade-in-delay-3{transition-delay:.3s;}

/* ══ SCROLL PROGRESS BAR ══ */
.scroll-progress{
  position:fixed;top:44px;left:0;z-index:299;
  height:2px;width:0;
  background:linear-gradient(90deg,var(--blue),var(--blue-ondark));
  pointer-events:none;
}

/* ══ HERO ENTRANCE REVEAL ══ */
.hero-h1 .line{display:block;overflow:hidden;}
.hero-h1 .line span{
  display:block;transform:translateY(110%);
  animation:lineUp 1s cubic-bezier(.16,1,.3,1) forwards;
}
.hero-h1 .line:nth-child(1) span{animation-delay:.15s;}
.hero-h1 .line:nth-child(2) span{animation-delay:.3s;}
.hero-h1 .line:nth-child(3) span{animation-delay:.45s;}
@keyframes lineUp{to{transform:translateY(0);}}
.hero-h1 .grad{
  background:linear-gradient(90deg,var(--blue-ondark) 0%,#7bc4ff 35%,#b5dcff 50%,#7bc4ff 65%,var(--blue-ondark) 100%);
  background-size:220% 100%;
  -webkit-background-clip:text;background-clip:text;color:transparent;
  animation:shimmer 7s ease-in-out infinite;
}
@keyframes shimmer{0%,100%{background-position:0% 0;}50%{background-position:100% 0;}}

/* ══ HERO ANNOUNCEMENT PILL ══ */
.hero-pill{
  display:inline-flex;align-items:center;gap:8px;
  font-size:13px;font-weight:400;letter-spacing:-.1px;line-height:1;
  color:rgba(255,255,255,.85);text-decoration:none;
  background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.18);
  -webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px);
  padding:8px 16px;border-radius:var(--r-pill);
  margin-bottom:var(--sp-lg);
  opacity:0;transform:translateY(16px);
  animation:fadeUp .9s cubic-bezier(.16,1,.3,1) .08s forwards;
  transition:background-color .3s ease,border-color .3s ease;
}
.hero-pill:hover{background:rgba(255,255,255,.15);border-color:rgba(255,255,255,.35);}
.hero-pill .pill-tag{color:var(--blue-ondark);font-weight:600;letter-spacing:.08em;}
.hero-pill .pill-arrow{transition:transform .3s cubic-bezier(.16,1,.3,1);}
.hero-pill:hover .pill-arrow{transform:translateX(3px);}
.hero-kicker,.hero-cta{
  opacity:0;transform:translateY(16px);
  animation:fadeUp .9s cubic-bezier(.16,1,.3,1) forwards;
}
.hero-kicker{animation-delay:.05s;}
.hero-cta{animation-delay:.55s;}
@keyframes fadeUp{to{opacity:1;transform:translateY(0);}}

/* ══ MARQUEE BAND ══ */
.marquee-band{
  background:var(--black);overflow:hidden;
  padding:20px 0;
  border-top:1px solid rgba(255,255,255,.08);
  border-bottom:1px solid rgba(255,255,255,.08);
  -webkit-mask-image:linear-gradient(90deg,transparent,#000 12%,#000 88%,transparent);
  mask-image:linear-gradient(90deg,transparent,#000 12%,#000 88%,transparent);
}
.marquee-track{
  display:flex;align-items:center;width:max-content;
  animation:marquee 36s linear infinite;
}
.marquee-band:hover .marquee-track{animation-play-state:paused;}
.marquee-item{
  font-size:13px;font-weight:400;letter-spacing:.25em;text-transform:uppercase;
  color:rgba(255,255,255,.38);white-space:nowrap;margin-right:56px;
}
.marquee-dot{width:4px;height:4px;border-radius:50%;background:var(--blue-ondark);opacity:.6;flex-shrink:0;margin-right:56px;}
@keyframes marquee{to{transform:translateX(-50%);}}

/* ══ FEATURE CARD SPOTLIGHT ══ */
.feature-card::after{
  content:'';position:absolute;inset:0;border-radius:inherit;
  background:radial-gradient(260px circle at var(--mx,50%) var(--my,50%),rgba(0,102,204,.09),transparent 65%);
  opacity:0;transition:opacity .35s ease;pointer-events:none;
}
.feature-card:hover::after{opacity:1;}

/* ══ DARK TILE AMBIENT GLOW ══ */
.cta-band{position:relative;overflow:hidden;}
.cta-band::before{
  content:'';position:absolute;top:-220px;left:50%;transform:translateX(-50%);
  width:680px;height:440px;
  background:radial-gradient(ellipse at center,rgba(0,113,227,.22),transparent 70%);
  pointer-events:none;
}
.cta-band-inner{position:relative;}

/* ══ BACK TO TOP ══ */
.to-top{
  position:fixed;right:22px;bottom:22px;z-index:280;
  width:44px;height:44px;border-radius:50%;
  background:rgba(0,0,0,.6);
  -webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);
  border:1px solid rgba(255,255,255,.16);
  color:var(--white);cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  opacity:0;visibility:hidden;transform:translateY(10px);
  transition:opacity .3s ease,visibility .3s ease,transform .3s ease,background-color .3s ease;
}
.to-top.show{opacity:1;visibility:visible;transform:translateY(0);}
.to-top:hover{background:var(--blue);border-color:var(--blue);}
.to-top svg{display:block;}

/* ══ IMAGE CURTAIN REVEAL — gated behind .js so images always show without JS ══ */
.js .img-reveal{clip-path:inset(0 100% 0 0);transition:clip-path 1.1s cubic-bezier(.16,1,.3,1);}
.js .img-reveal-right{clip-path:inset(0 0 0 100%);}
.js .img-reveal.visible{clip-path:inset(0 0 0 0);}

/* ══ HEADING BLUR-IN ══ */
.tile-h2.fade-in{
  filter:blur(8px);
  transition:opacity .6s ease,transform .6s ease,filter .8s ease;
}
.tile-h2.fade-in.visible{filter:blur(0);}

/* ══ STAT CELL INTERACTION ══ */
.stat-cell{transition:background-color .3s ease,transform .3s cubic-bezier(.16,1,.3,1);}
.stat-cell:hover{background:var(--white);transform:translateY(-3px);}
.stat-num{transition:color .3s ease;}
.stat-cell:hover .stat-num{color:var(--blue);}

/* ══ MFG ITEM MICRO-INTERACTION ══ */
.mfg-item-num{transition:letter-spacing .35s cubic-bezier(.16,1,.3,1),color .35s ease;}
.mfg-item:hover .mfg-item-num{letter-spacing:.25em;color:#7bc4ff;}

/* ══ CTA GLOW PULSE + TRUST CHIPS ══ */
.cta-band::before{animation:glowPulse 7s ease-in-out infinite;}
@keyframes glowPulse{
  0%,100%{opacity:.8;transform:translateX(-50%) scale(1);}
  50%{opacity:1;transform:translateX(-50%) scale(1.18);}
}
.cta-chips{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:var(--sp-xl);}
.cta-chip{
  font-size:12px;font-weight:400;letter-spacing:-.12px;line-height:1;
  color:var(--muted-dark);
  border:1px solid rgba(255,255,255,.16);
  padding:8px 14px;border-radius:var(--r-pill);
  transition:border-color .3s ease,color .3s ease;
}
.cta-chip:hover{border-color:var(--blue-ondark);color:var(--white);}

/* ══ GLOBAL PRESENCE DOT MAP ══ */
.map-wrap{position:relative;max-width:880px;margin:var(--sp-xxl) auto 0;}
#dotMap{display:block;width:100%;height:auto;}
.map-dot{fill:rgba(255,255,255,.22);opacity:0;transition:opacity .5s ease;}
.map-wrap.lit .map-dot{opacity:1;}
.map-marker{position:absolute;width:0;height:0;opacity:0;transition:opacity .8s ease 1.1s;}
.map-wrap.lit .map-marker{opacity:1;}
.marker-dot{
  position:absolute;left:0;top:0;width:9px;height:9px;margin:-4.5px 0 0 -4.5px;
  border-radius:50%;background:var(--blue-ondark);
  box-shadow:0 0 12px rgba(41,151,255,.9);
}
.marker-dot::after{
  content:'';position:absolute;inset:-4px;border-radius:50%;
  border:1px solid rgba(41,151,255,.6);
  animation:markerPulse 2.4s ease-out infinite;
}
.marker-hq .marker-dot{
  width:11px;height:11px;margin:-5.5px 0 0 -5.5px;
  background:var(--white);box-shadow:0 0 14px rgba(255,255,255,.9);
}
.marker-hq .marker-dot::after{border-color:rgba(255,255,255,.7);}
@keyframes markerPulse{0%{transform:scale(.6);opacity:1;}100%{transform:scale(2.6);opacity:0;}}
.marker-label{
  position:absolute;left:14px;top:0;transform:translateY(-50%);
  font-size:12px;font-weight:400;letter-spacing:-.12px;line-height:1;
  color:var(--white);white-space:nowrap;
  background:rgba(0,0,0,.55);
  border:1px solid rgba(255,255,255,.2);
  -webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);
  padding:6px 11px;border-radius:var(--r-pill);
}
.marker-up .marker-label{left:50%;top:auto;bottom:14px;transform:translateX(-50%);}
.marker-left .marker-label{left:auto;right:14px;}
.marker-down .marker-label{left:50%;top:14px;transform:translateX(-50%);}
@media(max-width:640px){.marker-label{font-size:10px;padding:4px 8px;}}

/* ══ SMALL POLISH ══ */
.nav-logo img{transition:opacity .3s ease,transform .3s cubic-bezier(.16,1,.3,1);}
.nav-logo:hover img{opacity:1;transform:scale(1.04);}
.marquee-item{transition:color .3s ease;}
.marquee-item:hover{color:rgba(255,255,255,.75);}
.scroll-hint{transition:opacity .4s ease;}

/* ══ REDUCED MOTION ══ */
@media(prefers-reduced-motion:reduce){
  .hero-h1 .line span,.hero-kicker,.hero-cta,.hero-pill{animation:none;transform:none;opacity:1;}
  .hero-tile video{animation:none;}
  .hero-h1 .grad{animation:none;}
  .cta-band::before{animation:none;}
  .marquee-track{animation:none;}
  .fade-in{opacity:1;transform:none;transition:none;filter:none;}
  .img-reveal{clip-path:inset(0 0 0 0);transition:none;}
  .map-dot{opacity:1;transition:none;}
  .map-marker{opacity:1;transition:none;}
  .marker-dot::after{animation:none;}
  html{scroll-behavior:auto;}
}
</style>
</head>
<body>

<!-- ══ SCROLL PROGRESS ══ -->
<div class="scroll-progress" id="scrollProgress"></div>

{% include "nav.njk" %}

<!-- ══ HERO TILE — dark video ══ -->
<div class="hero-tile">
