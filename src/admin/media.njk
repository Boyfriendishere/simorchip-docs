<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Media Manager — Simorchip</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:system-ui,-apple-system,sans-serif;background:#0f0f10;color:#f5f5f7;min-height:100vh;}

/* Main app */
.app{display:flex;flex-direction:column;min-height:100vh;}

/* Header */
.header{
  background:#1c1c1e;border-bottom:1px solid rgba(255,255,255,.08);
  padding:16px 24px;display:flex;align-items:center;gap:12px;
  position:sticky;top:0;z-index:10;
}
.header h1{font-size:17px;font-weight:600;flex:1;}
.header-folder{
  font-size:13px;color:#888;
  background:#2c2c2e;border:1px solid rgba(255,255,255,.08);
  border-radius:8px;padding:6px 12px;
}
.header-folder select{
  background:none;border:none;color:#f5f5f7;font-size:13px;
  outline:none;cursor:pointer;
}
.upload-btn{
  padding:8px 18px;border-radius:8px;background:#0a84ff;
  color:#fff;font-size:14px;font-weight:600;border:none;cursor:pointer;
  transition:background .2s;white-space:nowrap;
}
.upload-btn:hover{background:#0077ed;}

/* Drop zone */
.drop-zone{
  margin:24px;border:2px dashed rgba(255,255,255,.12);
  border-radius:14px;padding:32px;text-align:center;
  transition:border-color .2s,background .2s;cursor:pointer;
}
.drop-zone.drag-over{border-color:#0a84ff;background:rgba(10,132,255,.06);}
.drop-zone p{font-size:15px;color:#888;}
.drop-zone span{color:#0a84ff;font-weight:600;}
.drop-zone input{display:none;}

/* Progress */
.progress-bar{
  margin:0 24px 16px;background:#2c2c2e;border-radius:8px;
  overflow:hidden;display:none;height:4px;
}
.progress-bar.visible{display:block;}
.progress-fill{height:100%;background:#0a84ff;transition:width .3s;width:0%;}
.upload-status{margin:0 24px 16px;font-size:14px;color:#888;display:none;}
.upload-status.visible{display:block;}

/* Grid */
.grid-header{
  padding:0 24px 12px;display:flex;align-items:center;gap:8px;
}
.grid-count{font-size:13px;color:#888;}
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(160px,1fr));
  gap:12px;padding:0 24px 24px;flex:1;
}
.file-card{
  background:#1c1c1e;border:1px solid rgba(255,255,255,.08);
  border-radius:12px;overflow:hidden;cursor:pointer;
  transition:border-color .2s,transform .2s;position:relative;
  group:true;
}
.file-card:hover{border-color:rgba(10,132,255,.5);transform:translateY(-2px);}
.file-card.selected{border-color:#0a84ff;box-shadow:0 0 0 2px rgba(10,132,255,.3);}
.file-thumb{
  width:100%;aspect-ratio:16/10;object-fit:cover;
  background:#2c2c2e;display:block;
}
.file-info{padding:10px 12px;}
.file-name{
  font-size:12px;font-weight:500;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
  margin-bottom:2px;
}
.file-size{font-size:11px;color:#666;}
.file-actions{
  padding:8px 12px;display:flex;gap:6px;
  border-top:1px solid rgba(255,255,255,.06);
}
.file-action-btn{
  flex:1;padding:5px 0;border-radius:6px;font-size:12px;font-weight:500;
  border:1px solid rgba(255,255,255,.1);background:transparent;
  color:#f5f5f7;cursor:pointer;transition:background .15s;
  white-space:nowrap;
}
.file-action-btn:hover{background:rgba(255,255,255,.08);}
.file-action-btn.copy-btn:hover{background:rgba(10,132,255,.2);border-color:#0a84ff;color:#0a84ff;}
.file-action-btn.del-btn:hover{background:rgba(255,69,58,.15);border-color:#ff453a;color:#ff453a;}

/* Select mode (popup) */
.select-bar{
  background:#1c1c1e;border-top:1px solid rgba(255,255,255,.08);
  padding:16px 24px;display:none;
  justify-content:space-between;align-items:center;
  position:sticky;bottom:0;
}
.select-bar.visible{display:flex;}
.select-confirm{
  padding:10px 24px;border-radius:10px;background:#0a84ff;
  color:#fff;font-size:15px;font-weight:600;border:none;cursor:pointer;
}

/* Toast */
.toast{
  position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);
  background:#323235;color:#f5f5f7;padding:10px 18px;border-radius:10px;
  font-size:14px;opacity:0;transition:opacity .2s,transform .2s;pointer-events:none;
  z-index:100;
}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

.empty{padding:40px 24px;text-align:center;color:#555;font-size:15px;}
</style>
</head>
<body>

<!-- Main app -->
<div class="app" id="app">
  <div class="header">
    <h1>Media Manager</h1>
    <div class="header-folder">
      <select id="folderSelect"><option value="products">products/</option></select>
    </div>
    <button class="upload-btn" id="newFolderBtn" style="background:#2c2c2e;border:1px solid rgba(255,255,255,.15);">+ Folder</button>
    <label class="upload-btn" for="fileInput">Upload Images</label>
    <input type="file" id="fileInput" multiple accept="image/*" style="display:none">
  </div>

  <div class="drop-zone" id="dropZone">
    <p>Drop images here or <span>click to upload</span></p>
    <input type="file" multiple accept="image/*" id="dropInput">
  </div>

  <div class="progress-bar" id="progressBar"><div class="progress-fill" id="progressFill"></div></div>
  <div class="upload-status" id="uploadStatus"></div>

  <div class="grid-header">
    <span class="grid-count" id="gridCount"></span>
  </div>
  <div class="grid" id="grid"></div>

  <div class="select-bar" id="selectBar">
    <span id="selectedName" style="font-size:14px;color:#888;"></span>
    <button class="select-confirm" id="selectConfirm">Use This Image</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const WORKER = 'https://simorchip-cms-media.nake-design.workers.dev';
const IS_POPUP = window.opener !== null;

const secret = '{{ env.uploadSecret }}';
let selectedCard = null;
let selectedUrl = '';
let currentFolder = 'products';

async function init() {
  await loadFolders();
  if (IS_POPUP) document.getElementById('selectBar').classList.add('visible');
  loadFiles();
}

async function loadFolders() {
  const r = await fetch(`${WORKER}/folders`, {
    headers: { Authorization: `Bearer ${secret}` }
  });
  const { folders } = await r.json();
  const select = document.getElementById('folderSelect');
  select.innerHTML = '';
  (folders || []).forEach(f => {
    const opt = document.createElement('option');
    opt.value = f;
    opt.textContent = f + '/';
    select.appendChild(opt);
  });
  if (folders && folders.length > 0) {
    currentFolder = folders[0];
    select.value = currentFolder;
  }
}

document.getElementById('newFolderBtn').addEventListener('click', async () => {
  const name = prompt('New folder name:');
  if (!name) return;
  const safe = name.replace(/[^a-zA-Z0-9/_-]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
  if (!safe) { showToast('Invalid folder name.'); return; }
  await fetch(`${WORKER}/mkdir`, {
    method: 'POST',
    headers: { Authorization: `Bearer ${secret}`, 'Content-Type': 'application/json' },
    body: JSON.stringify({ folder: safe })
  });
  await loadFolders();
  document.getElementById('folderSelect').value = safe;
  currentFolder = safe;
  loadFiles();
  showToast(`Folder "${safe}" created.`);
});

// ── Files ─────────────────────────────────────────────────────────
async function loadFiles() {
  const r = await fetch(`${WORKER}/list?prefix=${currentFolder}/`, {
    headers: { Authorization: `Bearer ${secret}` }
  });
  const { files } = await r.json();
  renderGrid(files || []);
}

function renderGrid(files) {
  const grid = document.getElementById('grid');
  document.getElementById('gridCount').textContent = `${files.length} file${files.length !== 1 ? 's' : ''}`;
  if (!files.length) {
    grid.innerHTML = '<div class="empty">No images yet. Upload some above.</div>';
    return;
  }
  grid.innerHTML = '';
  files.forEach(f => {
    const name = f.key.split('/').pop();
    const size = (f.size / 1024).toFixed(0) + ' KB';
    const card = document.createElement('div');
    card.className = 'file-card';
    card.dataset.url = f.url;
    card.dataset.name = name;
    card.innerHTML = `
      <img class="file-thumb" src="${f.url}" loading="lazy" onerror="this.style.opacity='.2'">
      <div class="file-info">
        <div class="file-name" title="${name}">${name}</div>
        <div class="file-size">${size}</div>
      </div>
      <div class="file-actions">
        <button class="file-action-btn copy-btn">Copy URL</button>
        <button class="file-action-btn del-btn">Delete</button>
      </div>`;

    card.querySelector('.copy-btn').addEventListener('click', e => {
      e.stopPropagation();
      navigator.clipboard.writeText(f.url);
      showToast('URL copied!');
    });

    card.querySelector('.del-btn').addEventListener('click', async e => {
      e.stopPropagation();
      if (!confirm(`Delete "${name}"?`)) return;
      await fetch(`${WORKER}/delete`, {
        method: 'DELETE',
        headers: { Authorization: `Bearer ${secret}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: f.key })
      });
      showToast('Deleted.');
      loadFiles();
    });

    if (IS_POPUP) {
      card.addEventListener('click', () => {
        document.querySelectorAll('.file-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        selectedUrl = f.url;
        document.getElementById('selectedName').textContent = name;
      });
    }

    grid.appendChild(card);
  });
}

// ── Upload ────────────────────────────────────────────────────────
async function uploadFiles(files) {
  const bar = document.getElementById('progressBar');
  const fill = document.getElementById('progressFill');
  const status = document.getElementById('uploadStatus');
  bar.classList.add('visible');
  status.classList.add('visible');

  for (let i = 0; i < files.length; i++) {
    const f = files[i];
    status.textContent = `Uploading ${f.name} (${i + 1}/${files.length})…`;
    fill.style.width = `${Math.round((i / files.length) * 100)}%`;

    const fd = new FormData();
    fd.append('file', f);
    fd.append('folder', currentFolder);
    await fetch(`${WORKER}/upload`, {
      method: 'POST',
      headers: { Authorization: `Bearer ${secret}` },
      body: fd
    });
  }

  fill.style.width = '100%';
  status.textContent = `Done! ${files.length} file${files.length > 1 ? 's' : ''} uploaded.`;
  setTimeout(() => {
    bar.classList.remove('visible');
    status.classList.remove('visible');
    fill.style.width = '0%';
  }, 2000);

  loadFiles();
}

// File input
document.getElementById('fileInput').addEventListener('change', e => {
  if (e.target.files.length) uploadFiles(Array.from(e.target.files));
});

// Drop zone
const dropZone = document.getElementById('dropZone');
dropZone.addEventListener('click', () => document.getElementById('fileInput').click());
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('drag-over');
  const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'));
  if (files.length) uploadFiles(files);
});

// Folder select
document.getElementById('folderSelect').addEventListener('change', e => {
  currentFolder = e.target.value;
  loadFiles();
});

// Select confirm (popup mode)
document.getElementById('selectConfirm').addEventListener('click', () => {
  if (!selectedUrl) { showToast('Please select an image first.'); return; }
  if (window.opener) {
    window.opener.postMessage({ type: 'media-selected', url: selectedUrl }, '*');
    window.close();
  }
});

// ── Toast ─────────────────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2200);
}

init();
</script>
</body>
</html>
