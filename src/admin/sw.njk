---
permalink: /admin/sw.js
eleventyExcludeFromCollections: true
layout: false
---
const WORKER = 'https://simorchip-cms-media.nake-design.workers.dev';
const REPO = 'Boyfriendishere/simorchip-docs';
const MEDIA = 'src/_uploads';
const API_BASE = `https://api.github.com/repos/${REPO}/contents/${MEDIA}`;
const SECRET = '{{ env.uploadSecret }}';

const ghLog = [];

self.addEventListener('install', e => {
  e.waitUntil(self.skipWaiting());
});

self.addEventListener('activate', e => {
  e.waitUntil(self.clients.claim());
});

function fakesha(s) {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (Math.imul(31, h) + s.charCodeAt(i)) | 0;
  return Math.abs(h).toString(16).padStart(40, '0');
}

self.addEventListener('fetch', e => {
  const url = e.request.url;

  // Debug log endpoint
  if (url.endsWith('/admin/_sw-log')) {
    e.respondWith(new Response(JSON.stringify(ghLog, null, 2), {
      headers: { 'Content-Type': 'application/json' }
    }));
    return;
  }

  // Intercept GraphQL (Sveltia CMS uses POST /graphql for asset listing)
  if (e.request.method === 'POST' && url.includes('api.github.com/graphql')) {
    e.respondWith(handleGraphQL(e.request));
    return;
  }

  // Intercept Git Trees API — Sveltia fetches full repo tree to find media files
  if (e.request.method === 'GET' &&
      url.includes(`api.github.com/repos/${REPO}/git/trees/`)) {
    e.respondWith(handleGitTrees(e.request));
    return;
  }

  // Also keep REST interception for any individual file operations
  if (url.startsWith(API_BASE)) {
    e.respondWith(handleREST(e.request));
    return;
  }
});

// ── GraphQL intercept ─────────────────────────────────────────────────
async function handleGraphQL(req) {
  const bodyText = await req.text();

  // Log query snippet for debugging
  ghLog.push({ type: 'graphql', snippet: bodyText.slice(0, 600), t: Date.now() });
  if (ghLog.length > 50) ghLog.shift();

  // Forward to GitHub with original headers + body
  const ghRes = await fetch('https://api.github.com/graphql', {
    method: 'POST',
    headers: req.headers,
    body: bodyText
  });

  const responseText = await ghRes.text();

  // Only modify if this query is about our media folder
  if (!bodyText.includes('_uploads')) {
    return new Response(responseText, {
      status: ghRes.status,
      headers: { 'Content-Type': 'application/json; charset=utf-8' }
    });
  }

  // Get R2 files
  let r2entries = [];
  try {
    const r2 = await fetch(`${WORKER}/list?prefix=`, {
      headers: { Authorization: `Bearer ${SECRET}` }
    });
    if (r2.ok) {
      const { files } = await r2.json();
      r2entries = (files || [])
        .filter(f => !f.key.endsWith('.keep'))
        .map(f => ({
          __typename: 'TreeEntry',
          name: f.key.split('/').pop(),
          path: `${MEDIA}/${f.key}`,
          type: 'blob',
          oid: fakesha(f.key),
          object: { __typename: 'Blob', byteSize: f.size || 0, isBinary: true },
          blob: { __typename: 'Blob', byteSize: f.size || 0, isBinary: true }
        }));
    }
  } catch (_) {}

  const injectedTree = JSON.stringify({
    __typename: 'Tree',
    entries: r2entries
  });

  // Replace null media folder object with our R2 tree
  let modified = responseText
    .replace(/"object"\s*:\s*null/g, `"object":${injectedTree}`)
    .replace(/"entries"\s*:\s*\[\s*\]/g, `"entries":${JSON.stringify(r2entries)}`);

  return new Response(modified, {
    status: ghRes.status,
    headers: { 'Content-Type': 'application/json; charset=utf-8' }
  });
}

// ── Git Trees intercept ───────────────────────────────────────────────
async function handleGitTrees(req) {
  const log = { type: 'git-trees', url: req.url.slice(-60), t: Date.now() };
  ghLog.push(log);
  if (ghLog.length > 50) ghLog.shift();

  // Forward to GitHub to get the real tree
  const ghRes = await fetch(req.url, { headers: req.headers });
  log.ghStatus = ghRes.status;
  if (!ghRes.ok) { log.err = 'gh-fail'; return ghRes; }

  const data = await ghRes.json();
  log.origTreeLen = data.tree?.length;

  // Get R2 files and inject under src/_uploads/
  try {
    const r2 = await fetch(`${WORKER}/list?prefix=`, {
      headers: { Authorization: `Bearer ${SECRET}` }
    });
    log.r2Status = r2.status;
    if (r2.ok) {
      const { files } = await r2.json();
      log.r2Count = (files || []).length;
      const r2nodes = (files || [])
        .filter(f => !f.key.endsWith('.keep'))
        .map(f => ({
          path: `${MEDIA}/${f.key}`,
          mode: '100644',
          type: 'blob',
          sha: fakesha(f.key),
          size: f.size || 0,
          url: ''
        }));
      log.injected = r2nodes.length;

      data.tree = [
        ...(data.tree || []).filter(e => !e.path.startsWith(`${MEDIA}/`)),
        ...r2nodes
      ];
      data.truncated = false;
    }
  } catch (err) { log.err = String(err); }

  return new Response(JSON.stringify(data), {
    headers: { 'Content-Type': 'application/json; charset=utf-8' }
  });
}

// ── REST API intercept (individual file ops) ──────────────────────────
async function handleREST(req) {
  const url = new URL(req.url);
  const subpath = decodeURIComponent(
    url.pathname.replace(`/repos/${REPO}/contents/${MEDIA}`, '')
  ).replace(/^\//, '');

  if (req.method === 'GET' && !subpath) {
    const r = await fetch(`${WORKER}/list?prefix=`, {
      headers: { Authorization: `Bearer ${SECRET}` }
    });
    if (!r.ok) return new Response('[]', { headers: { 'Content-Type': 'application/json' } });
    const { files } = await r.json();
    const items = (files || [])
      .filter(f => !f.key.endsWith('.keep'))
      .map(f => {
        const sha = fakesha(f.key);
        return {
          type: 'file', name: f.key.split('/').pop(),
          path: `${MEDIA}/${f.key}`, sha, size: f.size || 0,
          download_url: f.url, url: `${API_BASE}/${f.key}`,
          html_url: f.url, git_url: '',
          _links: { self: `${API_BASE}/${f.key}`, git: '', html: f.url }
        };
      });
    return new Response(JSON.stringify(items), { headers: { 'Content-Type': 'application/json' } });
  }

  if (req.method === 'GET' && subpath) {
    const r2url = `https://pub-03642ec28edd4da6bcaf414c061b4ad6.r2.dev/${subpath}`;
    const sha = fakesha(subpath);
    return new Response(JSON.stringify({
      type: 'file', name: subpath.split('/').pop(),
      path: `${MEDIA}/${subpath}`, sha, size: 0,
      download_url: r2url, url: `${API_BASE}/${subpath}`,
      html_url: r2url, git_url: '',
      _links: { self: `${API_BASE}/${subpath}`, git: '', html: r2url }
    }), { headers: { 'Content-Type': 'application/json' } });
  }

  if (req.method === 'PUT') {
    const body = await req.json().catch(() => null);
    if (!body?.content) return Response.error();
    const b64 = body.content.replace(/\s/g, '');
    const bin = atob(b64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    const fileName = decodeURIComponent(url.pathname.split('/').pop());
    const fd = new FormData();
    fd.append('file', new File([bytes], fileName));
    fd.append('folder', 'products');
    const r = await fetch(`${WORKER}/upload`, {
      method: 'POST', headers: { Authorization: `Bearer ${SECRET}` }, body: fd
    });
    const { url: r2url, key } = await r.json();
    const sha = fakesha(key);
    return new Response(JSON.stringify({
      content: { name: fileName, path: `${MEDIA}/${key}`, sha, size: bytes.length, download_url: r2url, type: 'file' },
      commit: { sha: fakesha('c' + key), message: body.message || 'upload' }
    }), { status: 201, headers: { 'Content-Type': 'application/json' } });
  }

  if (req.method === 'DELETE') {
    const key = decodeURIComponent(
      url.pathname.replace(`/repos/${REPO}/contents/${MEDIA}/`, '')
    );
    await fetch(`${WORKER}/delete`, {
      method: 'DELETE',
      headers: { Authorization: `Bearer ${SECRET}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ key })
    });
    return new Response(JSON.stringify({ commit: { sha: fakesha('d' + key) } }), {
      headers: { 'Content-Type': 'application/json' }
    });
  }

  return fetch(req);
}
