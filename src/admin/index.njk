<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Simorchip — Content Manager</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
<button id="swDbg" style="position:fixed;bottom:8px;left:8px;z-index:9999;opacity:.3;font-size:10px;padding:4px 8px;border-radius:6px;background:#333;color:#fff;border:none;cursor:pointer;">SW</button>
<script>
document.getElementById('swDbg').onclick = async () => {
  const r = await fetch('/admin/_sw-log');
  const txt = await r.text();
  const existing = document.getElementById('_swOverlay');
  if (existing) existing.remove();
  const ov = document.createElement('div');
  ov.id = '_swOverlay';
  ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:99999;overflow:auto;padding:16px;box-sizing:border-box';
  ov.innerHTML = '<button onclick="document.getElementById(\'_swOverlay\').remove()" style="position:sticky;top:0;float:right;background:#fff;border:none;padding:4px 12px;cursor:pointer;font-size:14px;border-radius:4px">✕ 關閉</button>'
    + '<pre id="_swPre" style="color:#0f0;font-size:11px;white-space:pre-wrap;margin-top:8px;clear:both">' + (txt || '(empty)') + '</pre>';
  document.body.appendChild(ov);
};
</script>

<script>
(async () => {
  if (!('serviceWorker' in navigator)) { loadCMS(); return; }

  const reg = await navigator.serviceWorker.register('/admin/sw.js', { scope: '/admin/' });

  if (reg.installing || reg.waiting) {
    // New SW pending (installing/waiting to skipWaiting) — wait for it to claim the page
    await new Promise(r => navigator.serviceWorker.addEventListener('controllerchange', r, { once: true }));
  } else if (!navigator.serviceWorker.controller) {
    // SW registered but not yet controlling (very first install)
    await new Promise(r => navigator.serviceWorker.addEventListener('controllerchange', r, { once: true }));
  }
  // else: latest SW already in control — proceed immediately

  loadCMS();
})();

function loadCMS() {
  const s = document.createElement('script');
  s.type = 'module';
  s.src = 'https://unpkg.com/@sveltia/cms@^0.x/dist/sveltia-cms.js';
  document.head.appendChild(s);
}
</script>
</body>
</html>
