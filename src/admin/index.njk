<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Simorchip — Content Manager</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
<script>
(async () => {
  if ('serviceWorker' in navigator) {
    await navigator.serviceWorker.register('/admin/sw.js', { scope: '/admin/' });
    // Wait until a SW is active and controlling this page
    await navigator.serviceWorker.ready;
    if (!navigator.serviceWorker.controller) {
      await new Promise(r => navigator.serviceWorker.addEventListener('controllerchange', r, { once: true }));
    }
  }
  // Load Sveltia CMS only after SW is in control
  const s = document.createElement('script');
  s.type = 'module';
  s.src = 'https://unpkg.com/@sveltia/cms@^0.x/dist/sveltia-cms.js';
  document.head.appendChild(s);
})();
</script>
</body>
</html>
